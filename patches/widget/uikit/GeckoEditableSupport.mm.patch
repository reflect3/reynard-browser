+// In here, I separated the editable support code into two paths - modern and
+// legacy. This is because Apple introduced quite a few new APIs for text
+// editing in iOS 16 and 17, and on these versions the old APIs for older
+// versions just don't seem to work, so I have to maintain two separate code
+// paths so this could work on every iOS version that the browser support.
+// Also there are some touch/gestures differences (or conflicts?) on iOS 17+ as
+// well, so these have to be handled separately. Btw UIMenuController is
+// replaced with UIEditMenuInteraction on iOS 16, but seems like it continues to
+// work so I don't plan to use new API for that part just yet.
+
+// Things that aren't working yet:
+// - Dragging the spacebar to move the cursor to a different position.
+// - Triple-tapping to select a paragraph.
+// - Cross handle switching on newer path.
+// - Touch and hold to magnify the text, then move the insertion point by
+// dragging it.
+// - Tapping on an existing selection will only toggle the menu, not dismissing
+// it entirely.
+
+// See https://support.apple.com/en-vn/guide/iphone/iph1a9cae52c/ios
+
+@interface ChildView : UIView {
+ @public
+  // Redeclarations
+  nsWindow* mGeckoChild;
+  BOOL mWaitingForPaint;
+  NSMapTable<UITouch*, NSNumber*>* mTouches;
+  int mNextTouchID;
+  GeckoEditableState mEditable;
+  CALayer* mRootCALayer;
+  BOOL mIsUpdatingLayer;
+}
+@end
+
