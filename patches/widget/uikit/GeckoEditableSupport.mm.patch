+  return [ChildViewTextPosition positionWithOffset:[self documentLength]];
+}
+
+- (UITextRange*)textRangeFromPosition:(UITextPosition*)aFromPosition
+                           toPosition:(UITextPosition*)aToPosition {
+  ChildViewTextPosition* from = [self textPosForPosition:aFromPosition];
+  ChildViewTextPosition* to = [self textPosForPosition:aToPosition];
+  if (!from || !to) {
+    return nil;
+  }
+  return [ChildViewTextRange rangeWithStart:from end:to];
+}
+
+- (UITextPosition*)positionFromPosition:(UITextPosition*)aPosition
+                                 offset:(NSInteger)aOffset {
+  ChildViewTextPosition* from = [self textPosForPosition:aPosition];
+  if (!from) {
+    return nil;
+  }
+
+  NSInteger candidate = static_cast<NSInteger>(from.offset) + aOffset;
+  if (candidate < 0) {
+    candidate = 0;
+  }
+  return [ChildViewTextPosition
+      positionWithOffset:[self clampOffset:static_cast<NSUInteger>(candidate)]];
+}
+
+- (UITextPosition*)positionFromPosition:(UITextPosition*)aPosition
+                            inDirection:(UITextLayoutDirection)aDirection
+                                 offset:(NSInteger)aOffset {
+  NSInteger signedOffset = aOffset;
+  if (aDirection == UITextLayoutDirectionLeft ||
+      aDirection == UITextLayoutDirectionUp) {
+    signedOffset = -aOffset;
+  }
+  return [self positionFromPosition:aPosition offset:signedOffset];
+}
+
+- (NSComparisonResult)comparePosition:(UITextPosition*)aPosition
+                           toPosition:(UITextPosition*)aOther {
+  ChildViewTextPosition* lhs = [self textPosForPosition:aPosition];
+  ChildViewTextPosition* rhs = [self textPosForPosition:aOther];
+  if (!lhs || !rhs) {
+    return NSOrderedSame;
+  }
+  if (lhs.offset < rhs.offset) {
+    return NSOrderedAscending;
+  }
+  if (lhs.offset > rhs.offset) {
+    return NSOrderedDescending;
+  }
+  return NSOrderedSame;
+}
+
+- (NSInteger)offsetFromPosition:(UITextPosition*)aFrom
+                     toPosition:(UITextPosition*)aToPosition {
+  ChildViewTextPosition* start = [self textPosForPosition:aFrom];
+  ChildViewTextPosition* end = [self textPosForPosition:aToPosition];
+  if (!start || !end) {
+    return 0;
+  }
+  return static_cast<NSInteger>(end.offset) -
+         static_cast<NSInteger>(start.offset);
+}
+
+- (UITextPosition*)positionWithinRange:(UITextRange*)aRange
+                   farthestInDirection:(UITextLayoutDirection)aDirection {
+  ChildViewTextRange* textRange = [self textRangeForTextRange:aRange];
+  if (!textRange) {
+    return nil;
+  }
+
+  switch (aDirection) {
+    case UITextLayoutDirectionLeft:
+    case UITextLayoutDirectionUp:
+      return textRange.start;
+    default:
+      return textRange.end;
+  }
+}
+
+- (UITextRange*)characterRangeByExtendingPosition:(UITextPosition*)aPosition
+                                      inDirection:
+                                          (UITextLayoutDirection)aDirection {
+  ChildViewTextPosition* textPosition = [self textPosForPosition:aPosition];
+  if (!textPosition) {
+    return nil;
+  }
+
+  if (aDirection == UITextLayoutDirectionLeft ||
+      aDirection == UITextLayoutDirectionUp) {
+    UITextPosition* start = [self positionFromPosition:textPosition offset:-1];
+    if (!start) {
+      start = textPosition;
+    }
+    return [self textRangeFromPosition:start toPosition:textPosition];
+  }
+
+  UITextPosition* end = [self positionFromPosition:textPosition offset:1];
+  if (!end) {
+    end = textPosition;
+  }
+  return [self textRangeFromPosition:textPosition toPosition:end];
+}
+
+- (NSWritingDirection)baseWritingDirectionForPosition:(UITextPosition*)aPosition
+                                          inDirection:(UITextStorageDirection)
+                                                          aDirection {
+  return NSWritingDirectionNatural;
+}
