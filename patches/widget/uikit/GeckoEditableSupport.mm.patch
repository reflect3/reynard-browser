+  [mEditable.mMarkedTextStyle release];
+  mEditable.mMarkedTextStyle = [aMarkedTextStyle retain];
+}
+
+- (void)setMarkedText:(NSString*)aMarkedText
+        selectedRange:(NSRange)aSelectedRange {
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return;
+  }
+
+  mEditable.mCaretMenuActive = NO;
+  if ([self shouldUseVietnameseIMEPath]) {
+    // On the Vietnamese path, avoid delegate change notifications here. UIKit
+    // re-enters text queries during composition, and those notifications make
+    // the keyboard observe partially-applied Gecko state.
+    [self clearVietnameseBuffer];
+    handler->SetMarkedText(aMarkedText ?: @"", aSelectedRange);
+    [self scheduleEditSelectionUpdate];
+    return;
+  }
+
+  [mEditable.mTextInputDelegate textWillChange:self];
+  [mEditable.mTextInputDelegate selectionWillChange:self];
+  handler->SetMarkedText(aMarkedText ?: @"", aSelectedRange);
+  [mEditable.mTextInputDelegate textDidChange:self];
+  [mEditable.mTextInputDelegate selectionDidChange:self];
+  [self scheduleEditSelectionUpdate];
+}
+
+- (void)unmarkText {
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    if ([self hasVietnameseBuffer]) {
+      [self clearVietnameseMarkedRange];
+    }
+    return;
+  }
+
+  BOOL useVietnameseIMEPath = [self shouldUseVietnameseIMEPath];
+  NSRange markedRange = NSMakeRange(NSNotFound, 0);
+  if (useVietnameseIMEPath && (!handler->MarkedRange(markedRange) ||
+                               markedRange.location == NSNotFound)) {
+    [self clearVietnameseMarkedRange];
+    return;
+  }
+
+  mEditable.mCaretMenuActive = NO;
+  if (useVietnameseIMEPath) {
+    // Same as setMarkedText: do the Gecko operation without delegate calls
+    // while the Vietnamese IM is using the buffer.
+    handler->UnmarkText();
+    [self scheduleEditSelectionUpdate];
+    return;
+  }
+
+  [mEditable.mTextInputDelegate textWillChange:self];
+  [mEditable.mTextInputDelegate selectionWillChange:self];
+  handler->UnmarkText();
+  [mEditable.mTextInputDelegate textDidChange:self];
+  [mEditable.mTextInputDelegate selectionDidChange:self];
+  [self scheduleEditSelectionUpdate];
+}
