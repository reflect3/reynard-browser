+// MARK: UITextInteraction (Shared)
+
+// Lets UIKit text interactions begin and seeds handle tracking.
+- (BOOL)interactionShouldBegin:(UITextInteraction*)aInteraction
+                       atPoint:(CGPoint)aPoint {
+  // Somehow there's a non-owned UITextSelectionInteraction subclass causing
+  // overlapping duplicated selections on modern path CJK. So we allow only our
+  // owned interactions to trigger handle tracking.
+  if (aInteraction != mEditable.mEditableTextInteraction &&
+      aInteraction != mEditable.mNonEditableTextInteraction) {
+    return NO;
+  }
+
+  [self startHandleTrackingAtPoint:aPoint
+                             range:[self selectedRange]
+                           handler:[self textHandler]];
+  return YES;
+}
+
+- (void)interactionWillBegin:(UITextInteraction*)aInteraction {
+  mEditable.mTextInteractionInProgress = YES;
+  [[UIMenuController sharedMenuController] hideMenuFromView:self];
+  [self becomeFirstResponder];
+  if (mEditable.mSelectionDisplayInteraction != nil) {
+    [self updateHandleVisibility];
+  } else {
+    [self setLegacyGrabbersHidden:NO];
+  }
+
+  if (aInteraction != mEditable.mEditableTextInteraction &&
+      aInteraction != mEditable.mNonEditableTextInteraction) {
+    return;
+  }
+}
+
+// Cleans up state after a UIKit text interaction finishes.
+- (void)interactionDidEnd:(UITextInteraction*)aInteraction {
+  mEditable.mTextInteractionInProgress = NO;
+  if (mEditable.mSelectionDisplayInteraction != nil) {
+    [self updateHandleVisibility];
+    [self refreshSelectionUI];
+  } else {
+    [self updateLegacyGrabbers];
+  }
+  [self resetHandleState];
+  [self updateEditMenu];
+
+  if (aInteraction != mEditable.mEditableTextInteraction &&
+      aInteraction != mEditable.mNonEditableTextInteraction) {
+    return;
+  }
+}
+
+@end
+
+// MARK: - ChildView (Modern)
+
+@implementation ChildView (Modern)
+
+- (void)setupModernTextInput {
+  if (Class selectionDisplayInteractionClass =
+          NSClassFromString(@"UITextSelectionDisplayInteraction")) {
+    id selectionDisplayInteraction =
+        [[selectionDisplayInteractionClass alloc] initWithTextInput:self
+                                                           delegate:self];
+    mEditable.mSelectionDisplayInteraction =
+        [selectionDisplayInteraction retain];
+    [self addInteraction:mEditable.mSelectionDisplayInteraction];
+
+    mEditable.mSelectionHandlePanRecognizer = [[UIPanGestureRecognizer alloc]
+        initWithTarget:self
+                action:@selector(panSelectionHandle:)];
+    mEditable.mSelectionHandlePanRecognizer.delegate = self;
+    mEditable.mSelectionHandlePanRecognizer.maximumNumberOfTouches = 1;
+    mEditable.mSelectionHandlePanRecognizer.cancelsTouchesInView = YES;
+    [self addGestureRecognizer:mEditable.mSelectionHandlePanRecognizer];
+  }
+}
+
+- (void)teardownModernTextInput {
+  if ([(id)mEditable.mSelectionDisplayInteraction view] == self) {
+    [self removeInteraction:mEditable.mSelectionDisplayInteraction];
+  }
+  [mEditable.mSelectionDisplayInteraction release];
+  mEditable.mSelectionDisplayInteraction = nil;
+  if (mEditable.mSelectionHandlePanRecognizer) {
+    [self removeGestureRecognizer:mEditable.mSelectionHandlePanRecognizer];
+  }
+  [mEditable.mSelectionHandlePanRecognizer release];
+  mEditable.mSelectionHandlePanRecognizer = nil;
+}
+
+- (void)updateModernTextInteractions {
+  if (!mEditable.mEditableTextInteraction ||
+      !mEditable.mNonEditableTextInteraction) {
+    return;
+  }
+
+  const bool keyboardDisabled =
+      mGeckoChild && mGeckoChild->IsVirtualKeyboardDisabled();
+  if (keyboardDisabled) {
+    if (mEditable.mEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mEditableTextInteraction];
+    }
+    if (mEditable.mNonEditableTextInteraction.view != self) {
+      [self addInteraction:mEditable.mNonEditableTextInteraction];
+    }
+  } else {
+    if (mEditable.mNonEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mNonEditableTextInteraction];
+    }
+    if (mEditable.mEditableTextInteraction.view != self) {
+      [self addInteraction:mEditable.mEditableTextInteraction];
+    }
+  }
+
+  [self updateSelectionActivation];
+}
+
+// Keep iOS 17+ selection display active whenever the editable view
+// owns first responder, even when Gecko changes selection outside UIKit's
+// built-in text gestures.
+- (void)updateSelectionActivation {
+  if (mEditable.mSelectionDisplayInteraction == nil) {
+    return;
+  }
+
+  const BOOL shouldActivate =
+      mGeckoChild && !mGeckoChild->Destroyed() && [self isFirstResponder];
+  const BOOL isActivated =
+      [(id)mEditable.mSelectionDisplayInteraction isActivated];
+  if (isActivated != shouldActivate) {
+    [(id)mEditable.mSelectionDisplayInteraction setActivated:shouldActivate];
+  }
+}
+
+// This is mostly just for hiding the handles when they're offscreen, like when
+// the view is zoomed in and user just drag the view while a selection is active
+// and then the handle become outside of the visible area.
+- (void)updateHandleVisibility {
+  if (mEditable.mSelectionDisplayInteraction == nil) {
+    return;
+  }
+
+  const BOOL hasAttachedTextInteraction =
+      mEditable.mEditableTextInteraction.view == self ||
+      mEditable.mNonEditableTextInteraction.view == self;
+  CGRect visibleBounds = [self selectionBounds];
+  widget::TextInputHandler* handler = [self textHandler];
+  NSRange selectedRange = [self selectedRange];
+  BOOL startEndpointVisible = NO;
+  BOOL endEndpointVisible = NO;
+  if (handler && selectedRange.location != NSNotFound &&
+      selectedRange.length > 0) {
+    const EndpointRects visibleEndpoints =
+        [self visibleHandleRectsForRange:selectedRange handler:handler];
+    startEndpointVisible = visibleEndpoints.hasStart;
+    endEndpointVisible = visibleEndpoints.hasEnd;
+  }
+  NSArray* handleViews =
+      [(id)mEditable.mSelectionDisplayInteraction handleViews];
+  NSUInteger handleIndex = 0;
+  for (UIView* handleView in handleViews) {
+    BOOL shouldHide =
+        hasAttachedTextInteraction && mEditable.mTextInteractionInProgress;
+    if (!shouldHide) {
+      if (selectedRange.location != NSNotFound && selectedRange.length > 0 &&
+          [handleViews count] >= 2) {
+        // UIKit exposes the handle views as an ordered pair, so map index 0/1
+        // to Gecko's start/end endpoint visibility before doing final clipping.
+        if (handleIndex == 0) {
+          shouldHide = !startEndpointVisible;
+        } else if (handleIndex == 1) {
+          shouldHide = !endEndpointVisible;
+        }
+      }
+
+      // Trust Gecko's endpoint visibility over the UIKit handle view's
+      // frame, which includes decorative chrome (teardrop) that may be out
+      // past the editor bounds at line edges (and therefore make the entire
+      // handle hidden although it is supposed to be visible).
+      const BOOL geckoEndpointIsVisible =
+          (handleIndex == 0 && startEndpointVisible) ||
+          (handleIndex == 1 && endEndpointVisible);
+
+      if (!shouldHide && !geckoEndpointIsVisible) {
+        CGRect handleRect = [self convertRect:handleView.bounds
+                                     fromView:handleView];
+        shouldHide = CGRectIsEmpty(visibleBounds) ||
+                     CGRectIsNull(visibleBounds) ||
+                     !CGRectContainsRect(CGRectStandardize(visibleBounds),
+                                         CGRectStandardize(handleRect));
+      }
+    }
+    handleView.hidden = shouldHide;
+    handleIndex++;
+  }
+}
+
+- (void)refreshSelectionUI {
+  if (mEditable.mSelectionDisplayInteraction == nil) {
+    return;
+  }
+
+  [self updateSelectionActivation];
+  if ([(id)mEditable.mSelectionDisplayInteraction isActivated]) {
+    [(id)mEditable.mSelectionDisplayInteraction setNeedsSelectionUpdate];
+  }
+  [NSObject
+      cancelPreviousPerformRequestsWithTarget:self
+                                     selector:@selector(updateHandleVisibility)
+                                       object:nil];
+  [self performSelector:@selector(updateHandleVisibility)
+             withObject:nil
+             afterDelay:0
+                inModes:@[ NSRunLoopCommonModes ]];
+  [self updateHandleVisibility];
+}
+
+- (BOOL)gestureRecognizerShouldBegin:(UIGestureRecognizer*)aGestureRecognizer {
+  if (aGestureRecognizer != mEditable.mSelectionHandlePanRecognizer) {
+    return YES;
+  }
+
+  if (mEditable.mSelectionDisplayInteraction == nil ||
+      !mEditable.mSelectionHandlePanRecognizer) {
+    return NO;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return NO;
+  }
+
+  NSRange range = [self selectedRange];
+  if (range.location == NSNotFound || range.length == 0) {
+    return NO;
+  }
+
+  CGPoint point = [mEditable.mSelectionHandlePanRecognizer locationInView:self];
+  GeckoSelectionHandle handle = [self closestHandleToPoint:point
+                                                     range:range
+                                                   handler:handler];
+  return handle != GeckoSelectionHandleNone;
+}
+
+// Drive visible selection-handle drags on iOS 17+ when the passive
+// selection display interaction is showing the system handles but does not own
+// the drag gesture.
+- (void)panSelectionHandle:(UIPanGestureRecognizer*)aRecognizer {
+  if (mEditable.mSelectionDisplayInteraction == nil ||
+      aRecognizer != mEditable.mSelectionHandlePanRecognizer) {
+    return;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return;
+  }
+
+  CGPoint point = [aRecognizer locationInView:self];
+  switch (aRecognizer.state) {
+    case UIGestureRecognizerStateBegan: {
+      NSRange range = [self selectedRange];
+      [self startHandleTrackingAtPoint:point range:range handler:handler];
+      if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone) {
+        return;
+      }
+
+      mEditable.mTextInteractionInProgress = YES;
+      [self becomeFirstResponder];
+      [self refreshSelectionUI];
+      break;
+    }
+    case UIGestureRecognizerStateChanged: {
+      if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone ||
+          mEditable.mSelectionHandleAnchorOffset == NSNotFound) {
+        return;
+      }
+
+      // Translate the finger position into a predicted endpoint, then rebuild
+      // the dragged selection range against the fixed anchor offset.
+      ChildViewTextPosition* position =
+          [self textPosForPosition:[self closestPositionToPoint:point]];
+      if (!position) {
+        return;
+      }
+
+      NSUInteger anchorOffset =
+          [self clampOffset:mEditable.mSelectionHandleAnchorOffset];
+      ChildViewTextPosition* anchorPosition =
+          [ChildViewTextPosition positionWithOffset:anchorOffset];
+      ChildViewTextRange* draggedRange =
+          mEditable.mActiveSelectionHandle == GeckoSelectionHandleStart
+              ? [ChildViewTextRange rangeWithStart:position end:anchorPosition]
+              : [ChildViewTextRange rangeWithStart:anchorPosition end:position];
+      [self setSelectedTextRange:draggedRange];
+      [self refreshSelectionUI];
+      break;
+    }
+    case UIGestureRecognizerStateCancelled:
+    case UIGestureRecognizerStateEnded:
+    case UIGestureRecognizerStateFailed: {
+      if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone) {
+        return;
+      }
+
+      mEditable.mTextInteractionInProgress = NO;
+      [self refreshSelectionUI];
+      [self resetHandleState];
+      [self updateEditMenu];
+      break;
+    }
+    default:
+      break;
+  }
+}
+
+@end
+
+// MARK: - ChildView (Legacy)
+
+@implementation ChildView (Legacy)
+
+- (void)configureLegacyNonEditableTextInteractionGestures {
+  if (!mEditable.mNonEditableTextInteraction) {
+    return;
+  }
+
+  for (UIGestureRecognizer* gesture in mEditable.mNonEditableTextInteraction
+           .gesturesForFailureRequirements) {
+    gesture.delaysTouchesBegan = NO;
+    gesture.delaysTouchesEnded = NO;
+  }
+}
+
+- (void)updateLegacyTextInteractions {
+  if (!mEditable.mEditableTextInteraction ||
+      !mEditable.mNonEditableTextInteraction) {
+    return;
+  }
+
+  const bool keyboardDisabled =
+      mGeckoChild && mGeckoChild->IsVirtualKeyboardDisabled();
+  if (keyboardDisabled) {
+    if (mEditable.mEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mEditableTextInteraction];
+    }
+    if (mEditable.mNonEditableTextInteraction.view != self) {
+      [self addInteraction:mEditable.mNonEditableTextInteraction];
+    }
+    [self configureLegacyNonEditableTextInteractionGestures];
+  } else {
+    if (mEditable.mNonEditableTextInteraction.view == self) {
+      [self removeInteraction:mEditable.mNonEditableTextInteraction];
+    }
+    if (mEditable.mEditableTextInteraction.view != self) {
+      [self addInteraction:mEditable.mEditableTextInteraction];
+    }
+  }
+}
+
+// Older iOS keeps private selection grabbers alive at the clipped
+// viewport edge, so hide edge-snapped grabbers when the corresponding Gecko
+// endpoint is actually offscreen.
+- (void)updateLegacyGrabbers {
+  if (mEditable.mSelectionDisplayInteraction != nil || !self.window) {
+    return;
+  }
+
+  if (mEditable.mTextInteractionInProgress) {
+    [self setLegacyGrabbersHidden:NO];
+    return;
+  }
+
+  UITextRange* selectedTextRange = [self selectedTextRange];
+  if (!selectedTextRange || [selectedTextRange isEmpty]) {
+    return;
+  }
+
+  CGRect visibleBounds = [self selectionBounds];
+  if (CGRectIsEmpty(visibleBounds) || CGRectIsNull(visibleBounds)) {
+    return;
+  }
+
+  CGRect visibleBoundsInWindow = [self convertRect:visibleBounds
+                                            toView:self.window];
+  BOOL containsStart = NO;
+  BOOL containsEnd = NO;
+
+  // Marks which endpoints are genuinely visible after clipping
+  for (UITextSelectionRect* selectionRect in
+       [self selectionRectsForRange:selectedTextRange]) {
+    containsStart = containsStart || selectionRect.containsStart;
+    containsEnd = containsEnd || selectionRect.containsEnd;
+  }
+
+  NSMutableArray<UIView*>* grabberViews = [NSMutableArray array];
+  CollectViewsOfClass(self.window, @"UISelectionGrabber", grabberViews);
+
+  const CGFloat edgeTolerance = 6.0;
+  for (UIView* grabberView in grabberViews) {
+    CGRect grabberRect = [grabberView convertRect:grabberView.bounds
+                                           toView:self.window];
+    // Legacy grabbers often pin themselves to the viewport edge when the real
+    // endpoint scrolls offscreen. Detect that snapped position and hide only
+    // the endpoint whose selection rects said it is no longer actually visible.
+    const BOOL nearLeftEdge =
+        fabs(CGRectGetMinX(grabberRect) -
+             CGRectGetMinX(visibleBoundsInWindow)) <= edgeTolerance;
+    const BOOL nearRightEdge =
+        fabs(CGRectGetMaxX(grabberRect) -
+             CGRectGetMaxX(visibleBoundsInWindow)) <= edgeTolerance;
+    const BOOL nearTopEdge =
+        fabs(CGRectGetMinY(grabberRect) -
+             CGRectGetMinY(visibleBoundsInWindow)) <= edgeTolerance;
+    const BOOL nearBottomEdge =
+        fabs(CGRectGetMaxY(grabberRect) -
+             CGRectGetMaxY(visibleBoundsInWindow)) <= edgeTolerance;
+
+    BOOL shouldHide = NO;
+    if (!containsStart && (nearLeftEdge || nearTopEdge)) {
+      shouldHide = YES;
+    }
+    if (!containsEnd && (nearRightEdge || nearBottomEdge)) {
+      shouldHide = YES;
+    }
+    grabberView.hidden = shouldHide;
+  }
+}
+
+- (void)setLegacyGrabbersHidden:(BOOL)aHidden {
+  if (mEditable.mSelectionDisplayInteraction != nil || !self.window) {
+    return;
+  }
+
+  NSMutableArray<UIView*>* grabberViews = [NSMutableArray array];
+  CollectViewsOfClass(self.window, @"UISelectionGrabber", grabberViews);
+  for (UIView* grabberView in grabberViews) {
+    grabberView.hidden = aHidden;
+  }
+}
+
+@end
+
+// MARK: - ChildView (Vietnamese)
+
+@implementation ChildView (Vietnamese)
+
+- (BOOL)isVietnameseInputMode {
+  NSString* primaryLanguage = self.textInputMode.primaryLanguage;
+  return primaryLanguage && [primaryLanguage hasPrefix:@"vi"];
+}
+
+- (BOOL)hasVietnameseBuffer {
+  if (!mEditable.mVietnameseBufferText) {
+    return NO;
+  }
+  if ([self isVietnameseInputMode]) {
+    return YES;
+  }
+
+  // Also clear the buffer if the IM changes.
+  [self clearVietnameseBuffer];
+  return NO;
+}
+
+- (BOOL)shouldUseVietnameseIMEPath {
+  return [self hasVietnameseBuffer] || [self isVietnameseInputMode];
+}
+
+// Simply detect the Vietnamese word boundaries using whitespace.
+- (BOOL)isVietnameseWordSeparator:(unichar)aChar {
+  return [[NSCharacterSet whitespaceAndNewlineCharacterSet]
+      characterIsMember:aChar];
+}
+
+// Clears the temporary mirror
+- (void)clearVietnameseBuffer {
+  if (!mEditable.mVietnameseBufferText) {
+    return;
+  }
+  [mEditable.mVietnameseBufferText release];
+  mEditable.mVietnameseBufferText = nil;
+  mEditable.mVietnameseBufferSelection = NSMakeRange(NSNotFound, 0);
+  mEditable.mVietnameseBufferMarkedRange = NSMakeRange(NSNotFound, 0);
+  mEditable.mVietnamesePendingDeleteRange = NSMakeRange(NSNotFound, 0);
+  mEditable.mVietnameseBufferGeckoOffset = 0;
+  mEditable.mVietnameseBufferSyncAttempts = 0;
+}
+
+// Finds the current composing word around a UIKit-visible buffer offset.
+- (NSRange)vietnameseWordRangeAroundOffset:(NSUInteger)aOffset {
+  if (!mEditable.mVietnameseBufferText) {
+    return NSMakeRange(NSNotFound, 0);
+  }
+
+  NSUInteger textLength = [mEditable.mVietnameseBufferText length];
+  if (!textLength) {
+    return NSMakeRange(NSNotFound, 0);
+  }
+
+  NSUInteger offset = std::min(aOffset, textLength);
+  NSUInteger start = offset;
+  // Walk left until the beginning of the word or a separator.
+  while (start > 0 &&
+         ![self isVietnameseWordSeparator:[mEditable.mVietnameseBufferText
+                                              characterAtIndex:start - 1]]) {
+    start--;
+  }
+
+  NSUInteger end = offset;
+  // Walk right for the other half of the same composing word.
+  while (end < textLength &&
+         ![self isVietnameseWordSeparator:[mEditable.mVietnameseBufferText
+                                              characterAtIndex:end]]) {
+    end++;
+  }
+
+  if (start == end) {
+    return NSMakeRange(NSNotFound, 0);
+  }
+  return NSMakeRange(start, end - start);
+}
+
+// Stops reporting local marked text while keeping the buffer text itself.
+- (void)clearVietnameseMarkedRange {
+  if (mEditable.mVietnameseBufferMarkedRange.location == NSNotFound) {
+    return;
+  }
+  mEditable.mVietnameseBufferMarkedRange = NSMakeRange(NSNotFound, 0);
+}
+
+// Maintains the marked word after an edit to the buffer. Empty edits and
+// whitespace commits end Vietnamese word composition.
+- (void)updateVietnameseMarkedRangeAfterReplacingRange:(NSRange)aRange
+                                              withText:(NSString*)aText {
+  if (![self isVietnameseInputMode]) {
+    [self clearVietnameseMarkedRange];
+    return;
+  }
+
+  NSString* text = aText ?: @"";
+  if (![text length]) {
+    [self clearVietnameseMarkedRange];
+    return;
+  }
+
+  for (NSUInteger i = 0; i < [text length]; i++) {
+    // Any separator in the committed text means the composing word is done.
+    if ([self isVietnameseWordSeparator:[text characterAtIndex:i]]) {
+      [self clearVietnameseMarkedRange];
+      return;
+    }
+  }
+
+  NSRange wordRange =
+      [self vietnameseWordRangeAroundOffset:aRange.location + [text length]];
+  if (wordRange.location == NSNotFound) {
+    [self clearVietnameseMarkedRange];
+    return;
+  }
+
+  mEditable.mVietnameseBufferMarkedRange = wordRange;
+}
+
+// Converts a full Gecko text snapshot into the visible text that UIKit expects.
+- (NSString*)normalizedVietnameseBufferText:(NSString*)aText
+                                  selection:(NSRange*)aSelection
+                           geckoStartOffset:(NSUInteger*)aGeckoStartOffset {
+  if (aGeckoStartOffset) {
+    *aGeckoStartOffset = 0;
+  }
+  if (!aText || !mGeckoChild || mGeckoChild->Destroyed()) {
+    return aText ?: @"";
+  }
+
+  // Gecko text queries may include sentinel newlines that are not visible to
+  // UIKit. The Vietnamese buffer stores only visible text.
+  widget::InputContext context = mGeckoChild->GetInputContext();
+  NSString* text = aText;
+  NSUInteger length = [text length];
+  if (!length) {
+    return text;
+  }
+
+  if ([text characterAtIndex:0] == 0x0a) {
+    // Some Gecko text controls expose a leading newline sentinel. Track the
+    // offset so later buffer ranges can be converted back to Gecko ranges.
+    if (aGeckoStartOffset) {
+      *aGeckoStartOffset = 1;
+    }
+    if (aSelection && aSelection->location != NSNotFound) {
+      NSUInteger textLength = length - 1;
+      NSUInteger selectionLocation = std::min(aSelection->location, length);
+      NSUInteger selectionEnd =
+          std::min(aSelection->length, length - selectionLocation) +
+          selectionLocation;
+      NSUInteger location = selectionLocation > 1 ? selectionLocation - 1 : 0;
+      NSUInteger end = selectionEnd > 1 ? selectionEnd - 1 : 0;
+      location = std::min(location, textLength);
+      end = std::min(end, textLength);
+      if (end < location) {
+        end = location;
+      }
+      *aSelection = NSMakeRange(location, end - location);
+    }
+    text = [text substringFromIndex:1];
+    length = [text length];
+  }
+
+  if (!length) {
+    return text;
+  }
+
+  BOOL singleNewline = length == 1 && [text characterAtIndex:0] == 0x0a;
+  // Non-textarea controls may expose a trailing newline sentinel. Drop it when
+  // the current UIKit selection is at that visible end boundary.
+  if ((!singleNewline && context.mHTMLInputType.EqualsLiteral("textarea")) ||
+      [text characterAtIndex:length - 1] != 0x0a || !aSelection ||
+      aSelection->location == NSNotFound || aSelection->location > length) {
+    return text;
+  }
+
+  NSUInteger selectionEnd =
+      std::min(aSelection->length, length - aSelection->location) +
+      aSelection->location;
+  if (selectionEnd != length - 1 && selectionEnd != length) {
+    return text;
+  }
+
+  text = [text substringToIndex:length - 1];
+  if (aSelection && aSelection->location != NSNotFound) {
+    NSUInteger textLength = [text length];
+    NSUInteger location = std::min(aSelection->location, textLength);
+    NSUInteger selectionLength =
+        std::min(aSelection->length, textLength - location);
+    *aSelection = NSMakeRange(location, selectionLength);
+  }
+  return text;
+}
+
+// Starts the Vietnamese mirror from Gecko's current visible text and selection.
+// If the buffer already exists, only cancel pending cleanup work.
+- (BOOL)ensureVietnameseBufferWithHandler:(widget::TextInputHandler*)aHandler {
+  if (![self isVietnameseInputMode]) {
+    [self clearVietnameseBuffer];
+    return NO;
+  }
+
+  if ([self hasVietnameseBuffer]) {
+    [NSObject
+        cancelPreviousPerformRequestsWithTarget:self
+                                       selector:
+                                           @selector(
+                                               flushVietnamesePendingDelete)
+                                         object:nil];
+    [NSObject
+        cancelPreviousPerformRequestsWithTarget:self
+                                       selector:@selector(clearVietnameseBuffer)
+                                         object:nil];
+    return YES;
+  }
+  if (!aHandler) {
+    return NO;
+  }
+
+  NSRange selection = NSMakeRange(NSNotFound, 0);
+  BOOL usedUIKitSelection = NO;
+
+  // Prefer a UIKit selection that was just set by text interaction,
+  // because, once again, Gecko is lagging behind.
+  if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone &&
+      mEditable.mShadowSelectedRange.location != NSNotFound) {
+    selection = mEditable.mShadowSelectedRange;
+    usedUIKitSelection = YES;
+  } else if (!aHandler->SelectedRange(selection) ||
+             selection.location == NSNotFound) {
+    return NO;
+  }
+
+  nsString text;
+  if (!aHandler->TextInRange(NSMakeRange(0, UINT32_MAX), text)) {
+    return NO;
+  }
+
+  NSString* liveText = [NSString
+      stringWithCharacters:reinterpret_cast<const unichar*>(text.BeginReading())
+                    length:text.Length()];
+  NSUInteger geckoStartOffset = 0;
+  liveText = [self normalizedVietnameseBufferText:liveText
+                                        selection:&selection
+                                 geckoStartOffset:&geckoStartOffset];
+  NSUInteger liveLength = [liveText length];
+  NSUInteger location = std::min(selection.location, liveLength);
+  NSUInteger length = std::min(selection.length, liveLength - location);
+
+  mEditable.mVietnameseBufferText = [liveText mutableCopy];
+  mEditable.mVietnameseBufferSelection = NSMakeRange(location, length);
+  mEditable.mVietnameseBufferMarkedRange = NSMakeRange(NSNotFound, 0);
+  mEditable.mVietnamesePendingDeleteRange = NSMakeRange(NSNotFound, 0);
+  mEditable.mVietnameseBufferGeckoOffset = geckoStartOffset;
+  mEditable.mVietnameseBufferSyncAttempts = 0;
+  if (usedUIKitSelection) {
+    mEditable.mShadowSelectedRange = NSMakeRange(NSNotFound, 0);
+  }
+  return YES;
+}
+
+// Clears the mirror only after Gecko has caught up to the same text and
+// selection. Until then, UIKit queries continue to read from the buffer.
+- (BOOL)tryClearSyncedVietnameseBufferWithHandler:
+    (widget::TextInputHandler*)aHandler {
+  if (![self hasVietnameseBuffer] || !aHandler) {
+    return YES;
+  }
+
+  // Keep serving the buffer until Gecko reports matching text and selection.
+  mEditable.mVietnameseBufferSyncAttempts++;
+
+  NSRange liveSelection = NSMakeRange(NSNotFound, 0);
+  nsString liveText;
+  if (!aHandler->SelectedRange(liveSelection) ||
+      !aHandler->TextInRange(NSMakeRange(0, UINT32_MAX), liveText)) {
+    return NO;
+  }
+
+  NSString* liveString =
+      [NSString stringWithCharacters:reinterpret_cast<const unichar*>(
+                                         liveText.BeginReading())
+                              length:liveText.Length()];
+  liveString = [self normalizedVietnameseBufferText:liveString
+                                          selection:&liveSelection
+                                   geckoStartOffset:nullptr];
+  BOOL textMatches =
+      [liveString isEqualToString:mEditable.mVietnameseBufferText];
+  BOOL selectionMatches =
+      NSEqualRanges(liveSelection, mEditable.mVietnameseBufferSelection);
+  if (textMatches && selectionMatches) {
+    if (mEditable.mVietnameseBufferMarkedRange.location != NSNotFound) {
+      // A marked word is still active, so keep the mirror even though Gecko has
+      // the same plain text.
+      return YES;
+    }
+    [NSObject
+        cancelPreviousPerformRequestsWithTarget:self
+                                       selector:@selector(clearVietnameseBuffer)
+                                         object:nil];
+    [self performSelector:@selector(clearVietnameseBuffer)
+               withObject:nil
+               afterDelay:0.25
+                  inModes:@[ NSRunLoopCommonModes ]];
+    return YES;
+  }
+
+  if (mEditable.mVietnameseBufferSyncAttempts >= 10) {
+    // Avoid keeping stale state forever if Gecko never reports a matching
+    // snapshot for this composition.
+    [self clearVietnameseBuffer];
+    return YES;
+  }
+
+  return NO;
+}
+
+// Answers UITextInput text queries from the mirror when the requested range is
+// in UIKit-visible coordinates.
+- (NSString*)vietnameseBufferTextInRange:(NSRange)aRange {
+  if (![self hasVietnameseBuffer] || aRange.location == NSNotFound) {
+    return nil;
+  }
+
+  NSUInteger bufferLength = [mEditable.mVietnameseBufferText length];
+  if (aRange.location >= bufferLength) {
+    return @"";
+  }
+
+  NSUInteger length = std::min(aRange.length, bufferLength - aRange.location);
+  return [mEditable.mVietnameseBufferText
+      substringWithRange:NSMakeRange(aRange.location, length)];
+}
+
+// Converts a buffer range back to Gecko coordinates by restoring any hidden
+// leading sentinel offset removed during normalization.
+- (NSRange)geckoRangeForVietnameseBufferRange:(NSRange)aRange {
+  if (aRange.location == NSNotFound) {
+    return aRange;
+  }
+
+  NSUInteger geckoStartOffset = mEditable.mVietnameseBufferGeckoOffset;
+  if (aRange.location > NSUIntegerMax - geckoStartOffset) {
+    return NSMakeRange(NSNotFound, 0);
+  }
+
+  return NSMakeRange(aRange.location + geckoStartOffset, aRange.length);
+}
+
+- (NSRange)geckoRangeForVisibleRange:(NSRange)aRange {
+  if ([self hasVietnameseBuffer]) {
+    return [self geckoRangeForVietnameseBufferRange:aRange];
+  }
+  return aRange;
+}
+
+// Applies an edit to the local mirror first, then updates the local selection
+// and marked word so the next UIKit query sees a consistent state.
+- (void)replaceVietnameseBufferRange:(NSRange)aRange withText:(NSString*)aText {
+  if (![self hasVietnameseBuffer] || aRange.location == NSNotFound) {
+    return;
+  }
+
+  NSUInteger bufferLength = [mEditable.mVietnameseBufferText length];
+  NSUInteger location = std::min(aRange.location, bufferLength);
+  NSUInteger length = std::min(aRange.length, bufferLength - location);
+  NSString* text = aText ?: @"";
+  [mEditable.mVietnameseBufferText
+      replaceCharactersInRange:NSMakeRange(location, length)
+                    withString:text];
+  mEditable.mVietnameseBufferSelection =
+      NSMakeRange(location + [text length], 0);
+  [self updateVietnameseMarkedRangeAfterReplacingRange:NSMakeRange(location,
+                                                                   length)
+                                              withText:text];
+  mEditable.mVietnamesePendingDeleteRange = NSMakeRange(NSNotFound, 0);
+  mEditable.mVietnameseBufferSyncAttempts = 0;
+  [NSObject
+      cancelPreviousPerformRequestsWithTarget:self
+                                     selector:@selector(
+                                                  flushVietnamesePendingDelete)
+                                       object:nil];
+  [NSObject
+      cancelPreviousPerformRequestsWithTarget:self
+                                     selector:@selector(clearVietnameseBuffer)
+                                       object:nil];
+}
+
+// Computes the exact composed-character range that deleteBackward should remove
+// from the mirror.
+- (NSRange)vietnameseBufferDeleteBackwardRange {
+  if (![self hasVietnameseBuffer] ||
+      mEditable.mVietnameseBufferSelection.location == NSNotFound) {
+    return NSMakeRange(NSNotFound, 0);
+  }
+
+  NSRange selection = mEditable.mVietnameseBufferSelection;
+  if (selection.length) {
+    return selection;
+  }
+  if (selection.location == 0) {
+    return NSMakeRange(NSNotFound, 0);
+  }
+
+  return [mEditable.mVietnameseBufferText
+      rangeOfComposedCharacterSequenceAtIndex:selection.location - 1];
+}
+
+// Applies a deferred Gecko delete when a Vietnamese selected delete was not
+// followed by replacement text.
+- (void)flushVietnamesePendingDelete {
+  if (mEditable.mVietnamesePendingDeleteRange.location == NSNotFound) {
+    return;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return;
+  }
+
+  NSRange deleteRange = mEditable.mVietnamesePendingDeleteRange;
+  mEditable.mVietnamesePendingDeleteRange = NSMakeRange(NSNotFound, 0);
+  NSRange geckoDeleteRange =
+      [self geckoRangeForVietnameseBufferRange:deleteRange];
+  handler->ReplaceRange(geckoDeleteRange, @"");
+}
+
+@end
