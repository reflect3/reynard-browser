+// MARK: - UIKeyInput (Shared)
+
+- (void)insertText:(NSString*)aText {
+  if (!mGeckoChild || mGeckoChild->Destroyed()) {
+    return;
+  }
+  widget::TextInputHandler* handler = mGeckoChild->GetTextInputHandler();
+  if (!handler) {
+    return;
+  }
+
+  NSRange bufferEditRange = NSMakeRange(NSNotFound, 0);
+  BOOL hasBuffer = [self ensureVietnameseBufferWithHandler:handler];
+  mEditable.mCaretMenuActive = NO;
+  if (!hasBuffer) {
+    [mEditable.mTextInputDelegate textWillChange:self];
+    [mEditable.mTextInputDelegate selectionWillChange:self];
+    handler->InsertText(aText);
+    [mEditable.mTextInputDelegate textDidChange:self];
+    [mEditable.mTextInputDelegate selectionDidChange:self];
+    [self scheduleEditSelectionUpdate];
+    return;
+  }
+
+  // The buffer uses visible UIKit offsets; translate back to Gecko offsets
+  // before committing the text change.
+  BOOL hasPendingDelete =
+      mEditable.mVietnamesePendingDeleteRange.location != NSNotFound;
+  NSRange pendingDeleteRange = hasPendingDelete
+                                   ? mEditable.mVietnamesePendingDeleteRange
+                                   : NSMakeRange(NSNotFound, 0);
+  bufferEditRange = mEditable.mVietnameseBufferSelection;
+  NSRange geckoEditRange = [self
+      geckoRangeForVietnameseBufferRange:hasPendingDelete ? pendingDeleteRange
+                                                          : bufferEditRange];
+  handler->SetSelectedRange(geckoEditRange);
+
+  if (hasPendingDelete) {
+    // A previous selected delete was deferred; this insert is the replacement.
+    NSRange geckoPendingDeleteRange =
+        [self geckoRangeForVietnameseBufferRange:pendingDeleteRange];
+    handler->ReplaceRange(geckoPendingDeleteRange, aText ?: @"");
+  } else {
+    handler->InsertText(aText);
+  }
+  [self replaceVietnameseBufferRange:bufferEditRange withText:aText ?: @""];
+  [self scheduleEditSelectionUpdate];
+}
+
+- (void)deleteBackward {
+  if (!mGeckoChild || mGeckoChild->Destroyed()) {
+    return;
+  }
+  widget::TextInputHandler* handler = mGeckoChild->GetTextInputHandler();
+  if (!handler) {
+    return;
+  }
+
+  BOOL hasBuffer = [self ensureVietnameseBufferWithHandler:handler];
+  mEditable.mCaretMenuActive = NO;
+  if (!hasBuffer) {
+    [mEditable.mTextInputDelegate textWillChange:self];
+    handler->HandleCommand(Command::DeleteCharBackward);
+    [mEditable.mTextInputDelegate textDidChange:self];
+    [self scheduleEditSelectionUpdate];
+    return;
+  }
+
+  if (mEditable.mVietnamesePendingDeleteRange.location != NSNotFound) {
+    // Flush any older deferred delete before processing the next one.
+    [self flushVietnamesePendingDelete];
+  }
+
+  NSRange bufferSelection = mEditable.mVietnameseBufferSelection;
+  NSRange deleteRange = [self vietnameseBufferDeleteBackwardRange];
+  if (deleteRange.location == NSNotFound) {
+    return;
+  }
+
+  [self replaceVietnameseBufferRange:deleteRange withText:@""];
+  if (bufferSelection.length) {
+    // Vietnamese IM follow selected deleteBackward with insertText
+    // as a replacement, so defer the Gecko delete briefly.
+    mEditable.mVietnamesePendingDeleteRange = deleteRange;
+    [NSObject
+        cancelPreviousPerformRequestsWithTarget:self
+                                       selector:
+                                           @selector(
+                                               flushVietnamesePendingDelete)
+                                         object:nil];
+    [self performSelector:@selector(flushVietnamesePendingDelete)
+               withObject:nil
+               afterDelay:0.08
+                  inModes:@[ NSRunLoopCommonModes ]];
+  } else {
+    handler->ReplaceRange([self geckoRangeForVietnameseBufferRange:deleteRange],
+                          @"");
+  }
+  [self scheduleEditSelectionUpdate];
+}
+
+- (BOOL)hasText {
+  if (!mGeckoChild || mGeckoChild->Destroyed()) {
+    return NO;
+  }
+  widget::InputContext context = mGeckoChild->GetInputContext();
+  if (context.mIMEState.mEnabled == IMEEnabled::Disabled) {
+    return NO;
+  }
+  return YES;
+}
