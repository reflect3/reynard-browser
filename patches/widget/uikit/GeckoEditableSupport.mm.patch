+- (UITextPosition*)closestPositionToPoint:(CGPoint)aPoint
+                              withinRange:(UITextRange*)aRange {
+  (void)aRange;
+  return [self closestPositionToPoint:aPoint];
+}
+
+- (UITextRange*)characterRangeAtPoint:(CGPoint)aPoint {
+  UITextPosition* position = [self closestPositionToPoint:aPoint];
+  if (!position) {
+    return nil;
+  }
+  return [self textRangeFromPosition:position toPosition:position];
+}
