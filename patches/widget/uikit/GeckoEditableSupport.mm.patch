+- (BOOL)cachedHandleRect:(CGRect*)aRect
+               forOffset:(NSUInteger)aOffset
+                  handle:(GeckoSelectionHandle)aHandle;
+- (BOOL)caretRect:(CGRect*)aRect
+         atOffset:(NSUInteger)aOffset
