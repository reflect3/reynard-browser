+// Apparently, in simple terms, the Vietnamese keyboard works by checking the
+// typed characters for a word repeatedly to see if they can form a valid
+// Vietnamese word, then do some select / delete / insert magic to turn those
+// characters into the correct Vietnamese word. So the problem here is that
+// Gecko is lagging behind in terms of text updates, so the repeated checks and
+// edits would stay out of sync and produce incorrect results.
+
+// So the solution that I use here is to maintain a mirror of the text and
+// selection for the currently composing word, make UIKit interact with the
+// mirror instead. Once the composition is committed and Gecko's state catches
+// up, the mirror is cleared.
+
+@interface ChildView (Vietnamese)
+
+- (void)clearVietnameseBuffer;
+- (BOOL)hasVietnameseBuffer;
+- (BOOL)shouldUseVietnameseIMEPath;
+- (void)clearVietnameseMarkedRange;
+- (BOOL)ensureVietnameseBufferWithHandler:(widget::TextInputHandler*)aHandler;
+- (BOOL)tryClearSyncedVietnameseBufferWithHandler:
+    (widget::TextInputHandler*)aHandler;
+- (NSString*)vietnameseBufferTextInRange:(NSRange)aRange;
+- (NSRange)geckoRangeForVietnameseBufferRange:(NSRange)aRange;
+- (NSRange)geckoRangeForVisibleRange:(NSRange)aRange;
+- (void)replaceVietnameseBufferRange:(NSRange)aRange withText:(NSString*)aText;
+- (NSRange)vietnameseBufferDeleteBackwardRange;
+- (void)flushVietnamesePendingDelete;
+
+@end
