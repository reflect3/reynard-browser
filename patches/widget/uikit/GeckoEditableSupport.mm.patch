+// MARK: - ChildView (Shared)
+
+@implementation ChildView (Shared)
+
+- (void)setupTextInput {
+  mEditable.mTokenizer =
+      [[UITextInputStringTokenizer alloc] initWithTextInput:self];
+  mEditable.mTextInputDelegate = nil;
+  mEditable.mMarkedTextStyle = nil;
+  mEditable.mEditableTextInteraction = nil;
+  mEditable.mNonEditableTextInteraction = nil;
+  mEditable.mSelectionDisplayInteraction = nil;
+  mEditable.mSelectionHandlePanRecognizer = nil;
+  mEditable.mTextInteractionInProgress = NO;
+  mEditable.mPendingSelectionGeometryRefresh = NO;
+  // The other Vietnamese fields are meaningful only while this buffer exists.
+  mEditable.mVietnameseBufferText = nil;
+  [self resetHandleState];
+
+  mEditable.mEditableTextInteraction = [[UITextInteraction
+      textInteractionForMode:UITextInteractionModeEditable] retain];
+  mEditable.mEditableTextInteraction.textInput = self;
+  mEditable.mEditableTextInteraction.delegate = self;
+
+  mEditable.mNonEditableTextInteraction = [[UITextInteraction
+      textInteractionForMode:UITextInteractionModeNonEditable] retain];
+  mEditable.mNonEditableTextInteraction.textInput = self;
+  mEditable.mNonEditableTextInteraction.delegate = self;
+
+  [self setupModernTextInput];
+  [self updateTextInteractions];
+}
+
+- (void)teardownTextInput {
+  [mEditable.mTokenizer release];
+  mEditable.mTokenizer = nil;
+  [mEditable.mMarkedTextStyle release];
+  mEditable.mMarkedTextStyle = nil;
+  [mEditable.mEditableTextInteraction release];
+  mEditable.mEditableTextInteraction = nil;
+  [mEditable.mNonEditableTextInteraction release];
+  mEditable.mNonEditableTextInteraction = nil;
+  mEditable.mTextInteractionInProgress = NO;
+  // Drop any temporary Vietnamese mirror before releasing UIKit interactions.
+  [self clearVietnameseBuffer];
+
+  [self teardownModernTextInput];
+  [self resetHandleState];
+}
+
+// Returns the live Gecko text-input bridge for this view.
+- (widget::TextInputHandler*)textHandler {
+  if (!mGeckoChild || mGeckoChild->Destroyed()) {
+    return nullptr;
+  }
+  return mGeckoChild->GetTextInputHandler();
+}
+
+- (NSRange)selectedRange {
+  NSRange range = NSMakeRange(0, 0);
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler || !handler->SelectedRange(range)) {
+    return NSMakeRange(NSNotFound, 0);
+  }
+  return range;
+}
+
+- (NSUInteger)documentLength {
+  // During Vietnamese composition, answer length from the mirror so UIKit
+  // sees the text that the keyboard just edited, not stale Gecko state.
+  if ([self hasVietnameseBuffer]) {
+    return [mEditable.mVietnameseBufferText length];
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return 0;
+  }
+
+  uint32_t length = 0;
+  if (handler->TextLength(length)) {
+    return length;
+  }
+
+  return 0;
+}
+
+// Clamps an offset to the current document length.
+- (NSUInteger)clampOffset:(NSUInteger)aOffset {
+  NSUInteger length = [self documentLength];
+  return aOffset > length ? length : aOffset;
+}
+
+// The next 4 functions are just casting/conversion functions
+- (ChildViewTextPosition*)textPosForPosition:(UITextPosition*)aPosition {
+  if (!aPosition || ![aPosition isKindOfClass:[ChildViewTextPosition class]]) {
+    return nil;
+  }
+  return static_cast<ChildViewTextPosition*>(aPosition);
+}
+
+- (ChildViewTextRange*)textRangeForTextRange:(UITextRange*)aRange {
+  if (!aRange) {
+    return nil;
+  }
+
+  ChildViewTextPosition* start = [self textPosForPosition:aRange.start];
+  ChildViewTextPosition* end = [self textPosForPosition:aRange.end];
+  if (!start || !end) {
+    return nil;
+  }
+
+  return [ChildViewTextRange rangeWithStart:start end:end];
+}
+
+- (ChildViewTextRange*)textRangeForExactRange:(NSRange)aRange {
+  if (aRange.location == NSNotFound) {
+    return nil;
+  }
+
+  NSUInteger end = aRange.location;
+  if (aRange.location <= NSUIntegerMax - aRange.length) {
+    end = aRange.location + aRange.length;
+  }
+
+  ChildViewTextPosition* startPosition =
+      [ChildViewTextPosition positionWithOffset:aRange.location];
+  ChildViewTextPosition* endPosition =
+      [ChildViewTextPosition positionWithOffset:end];
+  return [ChildViewTextRange rangeWithStart:startPosition end:endPosition];
+}
+
+- (ChildViewTextRange*)textRangeForRange:(NSRange)aRange {
+  NSUInteger start = [self clampOffset:aRange.location];
+  NSUInteger end = [self clampOffset:aRange.location + aRange.length];
+  if (end < start) {
+    end = start;
+  }
+  ChildViewTextPosition* startPosition =
+      [ChildViewTextPosition positionWithOffset:start];
+  ChildViewTextPosition* endPosition =
+      [ChildViewTextPosition positionWithOffset:end];
+  return [ChildViewTextRange rangeWithStart:startPosition end:endPosition];
+}
+
+- (NSRange)rangeForTextRange:(UITextRange*)aRange {
+  ChildViewTextRange* textRange = [self textRangeForTextRange:aRange];
+  if (!textRange) {
+    return NSMakeRange(NSNotFound, 0);
+  }
+
+  NSUInteger start = textRange.startPosition.offset;
+  NSUInteger end = textRange.endPosition.offset;
+  if (end < start) {
+    NSUInteger tmp = start;
+    start = end;
+    end = tmp;
+  }
+
+  return NSMakeRange(start, end - start);
+}
+
+- (void)resetHandleState {
+  mEditable.mActiveSelectionHandle = GeckoSelectionHandleNone;
+  mEditable.mSelectionHandleAnchorOffset = NSNotFound;
+
+  // The shadow range here is the prediction to be applied to UIKit while a
+  // handle is being dragged. The reason that this is used is because Gecko's
+  // selection updates are lagged behind UIKit's, so without this the selection
+  // handles just end up flickering.
+  mEditable.mShadowSelectedRange = NSMakeRange(NSNotFound, 0);
+
+  mEditable.mShadowActiveHandleRect = CGRectZero;
+  mEditable.mShadowActiveHandleOffset = NSNotFound;
+  mEditable.mLineBoundaryStart = 0;
+  mEditable.mLineBoundaryEnd = NSUIntegerMax;
+  mEditable.mLineBoundariesComputed = NO;
+  mEditable.mVerticalBoundaryTop = -CGFLOAT_MAX;
+  mEditable.mVerticalBoundaryBottom = CGFLOAT_MAX;
+  mEditable.mVerticalBoundariesComputed = NO;
+}
+
+// Returns the visible editable regions, which is later used to check if
+// handles,  highlights, and carets are offscreen and therefore prevent them
+// from snapping to hidden content.
+- (CGRect)selectionBounds {
+  CGRect bounds = self.bounds;
+  if (CGRectIsEmpty(bounds) || CGRectIsNull(bounds)) {
+    return CGRectZero;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  LayoutDeviceIntRect editorRect;
+  bool hasEditorRect = handler && handler->EditorRect(editorRect);
+  if (hasEditorRect) {
+    bounds = DevPixelsToUIKitPoints(editorRect, [self contentScaleFactor]);
+    if (!ClipCGRectToBounds(bounds, self.bounds)) {
+      return CGRectZero;
+    }
+  }
+
+  return bounds;
+}
+
+- (BOOL)clipToSelectionBounds:(CGRect*)aRect {
+  if (!aRect) {
+    return NO;
+  }
+
+  // Intersect the caller's rect with the currently visible editable viewport.
+  // If the editor is fully clipped away, clear the rect so downstream callers
+  // can treat the geometry as unavailable instead of partially offscreen.
+  CGRect bounds = [self selectionBounds];
+  if (CGRectIsEmpty(bounds) || CGRectIsNull(bounds)) {
+    *aRect = CGRectZero;
+    return NO;
+  }
+
+  return ClipCGRectToBounds(*aRect, bounds);
+}
+
+// Checks if a rect is fully visible within the selection bounds.
+// This is used for checking whether we should show caret / selection handles or
+// not.
+- (BOOL)isRectFullyVisibleInSelectionBounds:(CGRect)aRect {
+  if (CGRectIsEmpty(aRect) || CGRectIsNull(aRect)) {
+    return NO;
+  }
+
+  CGRect bounds = [self selectionBounds];
+  if (CGRectIsEmpty(bounds) || CGRectIsNull(bounds)) {
+    return NO;
+  }
+
+  return CGRectContainsRect(CGRectStandardize(bounds),
+                            CGRectStandardize(aRect));
+}
+
+// When Gecko's live selection lags behind UIKit's shadow selection
+// during fast handle drags, reuse the predicted active-handle rect so UIKit
+// keeps a stable endpoint instead of temporarily dropping that handle.
+- (BOOL)cachedHandleRect:(CGRect*)aRect
+               forOffset:(NSUInteger)aOffset
+                  handle:(GeckoSelectionHandle)aHandle {
+  if (!aRect || aHandle == GeckoSelectionHandleNone ||
+      mEditable.mActiveSelectionHandle != aHandle ||
+      mEditable.mShadowActiveHandleOffset == NSNotFound ||
+      mEditable.mShadowActiveHandleOffset != aOffset ||
+      CGRectIsEmpty(mEditable.mShadowActiveHandleRect)) {
+    return NO;
+  }
+
+  *aRect = mEditable.mShadowActiveHandleRect;
+  if (![self isRectFullyVisibleInSelectionBounds:*aRect]) {
+    *aRect = CGRectZero;
+    return NO;
+  }
+  return YES;
+}
+
+// Returns the caret rect for a given character offset.
+- (BOOL)caretRect:(CGRect*)aRect
+         atOffset:(NSUInteger)aOffset
+          handler:(widget::TextInputHandler*)aHandler {
+  if (!aRect || !aHandler) {
+    return NO;
+  }
+
+  NSRange geckoRange = [self geckoRangeForVisibleRange:NSMakeRange(aOffset, 0)];
+  if (geckoRange.location == NSNotFound || geckoRange.location > UINT32_MAX) {
+    *aRect = CGRectZero;
+    return NO;
+  }
+
+  LayoutDeviceIntRect caretRect;
+  if (!aHandler->CaretRectForOffset(static_cast<uint32_t>(geckoRange.location),
+                                    caretRect)) {
+    *aRect = CGRectZero;
+    return NO;
+  }
+
+  *aRect = DevPixelsToUIKitPoints(caretRect, [self contentScaleFactor]);
+  aRect->size.width = 2.0;
+  return YES;
+}
+
+// Returns the rect for a selection endpoint.
+- (BOOL)handleRect:(CGRect*)aRect
+          atOffset:(NSUInteger)aOffset
+            handle:(GeckoSelectionHandle)aHandle
+           handler:(widget::TextInputHandler*)aHandler {
+  if (!aRect) {
+    return NO;
+  }
+
+  CGRect caretRect = CGRectZero;
+  if (![self caretRect:&caretRect atOffset:aOffset handler:aHandler]) {
+    if ([self cachedHandleRect:aRect forOffset:aOffset handle:aHandle]) {
+      return YES;
+    }
+    return NO;
+  }
+
+  *aRect = caretRect;
+  return YES;
+}
+
+// Returns a visible endpoint rect clipped to the editable bounds.
+- (BOOL)visibleHandleRect:(CGRect*)aRect
+                 atOffset:(NSUInteger)aOffset
+                   handle:(GeckoSelectionHandle)aHandle
+                  handler:(widget::TextInputHandler*)aHandler {
+  if (![self handleRect:aRect
+               atOffset:aOffset
+                 handle:aHandle
+                handler:aHandler]) {
+    return NO;
+  }
+
+  if (![self isRectFullyVisibleInSelectionBounds:*aRect]) {
+    *aRect = CGRectZero;
+    return NO;
+  }
+
+  return YES;
+}
+
+// Returns the visible rects for the selection endpoints of a given range, and
+// whether each endpoint is visible at all. This is used for hit-testing which
+// endpoint the user is trying to drag, and also for deciding when to hide the
+// handles because they're offscreen.
+- (EndpointRects)visibleHandleRectsForRange:(NSRange)aRange
+                                    handler:
+                                        (widget::TextInputHandler*)aHandler {
+  EndpointRects rects = {};
+  if (!aHandler || aRange.location == NSNotFound) {
+    return rects;
+  }
+
+  const NSUInteger startOffset = [self clampOffset:aRange.location];
+  const NSUInteger endOffset =
+      [self clampOffset:aRange.location + aRange.length];
+  const GeckoSelectionHandle startHandle =
+      aRange.length > 0 ? GeckoSelectionHandleStart : GeckoSelectionHandleNone;
+  const GeckoSelectionHandle endHandle =
+      aRange.length > 0 ? GeckoSelectionHandleEnd : GeckoSelectionHandleNone;
+
+  rects.hasStart = [self visibleHandleRect:&rects.startRect
+                                  atOffset:startOffset
+                                    handle:startHandle
+                                   handler:aHandler];
+  rects.hasEnd = [self visibleHandleRect:&rects.endRect
+                                atOffset:endOffset
+                                  handle:endHandle
+                                 handler:aHandler];
+  return rects;
+}
+
+// Estimates the horizontal step size that should move the dragged endpoint by
+// one character. It samples neighboring caret rects on the same visual line,
+// then falls back to a fixed width when Gecko cannot provide usable geometry.
+- (CGFloat)charWidthAtOffset:(NSUInteger)aOffset
+                   caretRect:(CGRect)aCaretRect
+                     handler:(widget::TextInputHandler*)aHandler {
+  if (!aHandler) {
+    return kFallbackCharWidth;
+  }
+
+  CGFloat characterWidth = 0;
+  CGRect neighborRect = CGRectZero;
+  const NSUInteger textLength = [self documentLength];
+  if (aOffset < textLength &&
+      [self caretRect:&neighborRect atOffset:aOffset + 1 handler:aHandler] &&
+      RectsShareVisualLine(aCaretRect, neighborRect)) {
+    characterWidth =
+        fabs(CGRectGetMinX(neighborRect) - CGRectGetMinX(aCaretRect));
+  }
+  if (characterWidth < 0.5 && aOffset > 0 &&
+      [self caretRect:&neighborRect atOffset:aOffset - 1 handler:aHandler] &&
+      RectsShareVisualLine(aCaretRect, neighborRect)) {
+    characterWidth =
+        fabs(CGRectGetMinX(aCaretRect) - CGRectGetMinX(neighborRect));
+  }
+
+  return characterWidth >= 0.5 ? characterWidth : kFallbackCharWidth;
+}
+
+// Determines which visible selection endpoint the touch is trying to grab.
+// Offscreen handles are ignored, and taps outside the handle hit radius will
+// not start a drag.
+- (GeckoSelectionHandle)closestHandleToPoint:(CGPoint)aPoint
+                                       range:(NSRange)aRange
+                                     handler:
+                                         (widget::TextInputHandler*)aHandler {
+  if (!aHandler || aRange.location == NSNotFound || aRange.length == 0) {
+    return GeckoSelectionHandleNone;
+  }
+
+  const EndpointRects rects = [self visibleHandleRectsForRange:aRange
+                                                       handler:aHandler];
+  if (!rects.hasStart && !rects.hasEnd) {
+    return GeckoSelectionHandleNone;
+  }
+
+  CGFloat lowerDistance =
+      rects.hasStart ? DistanceToSelectionHandle(aPoint, rects.startRect)
+                     : CGFLOAT_MAX;
+  CGFloat upperDistance = rects.hasEnd
+                              ? DistanceToSelectionHandle(aPoint, rects.endRect)
+                              : CGFLOAT_MAX;
+  if (std::min(lowerDistance, upperDistance) > kHandleHitRadius) {
+    return GeckoSelectionHandleNone;
+  }
+
+  return lowerDistance <= upperDistance ? GeckoSelectionHandleStart
+                                        : GeckoSelectionHandleEnd;
+}
+
+// Starts tracking the selection handle nearest to the touch point and make the
+// opposite handle stable. During dragging, only the active handle update its
+// position while the other stays fixed.
+- (void)startHandleTrackingAtPoint:(CGPoint)aPoint
+                             range:(NSRange)aRange
+                           handler:(widget::TextInputHandler*)aHandler {
+  [NSObject cancelPreviousPerformRequestsWithTarget:self
+                                           selector:@selector(resetHandleState)
+                                             object:nil];
+  [self resetHandleState];
+
+  GeckoSelectionHandle handle = [self closestHandleToPoint:aPoint
+                                                     range:aRange
+                                                   handler:aHandler];
+  if (handle == GeckoSelectionHandleNone) {
+    return;
+  }
+
+  NSUInteger lower = [self clampOffset:aRange.location];
+  NSUInteger upper = [self clampOffset:aRange.location + aRange.length];
+
+  mEditable.mActiveSelectionHandle = handle;
+  mEditable.mSelectionHandleAnchorOffset =
+      handle == GeckoSelectionHandleStart ? upper : lower;
+
+  NSUInteger handleOffset = handle == GeckoSelectionHandleStart ? lower : upper;
+
+  // Seed the shadow so closestPositionToPoint always has a valid base.
+  CGRect initialRect;
+  if ([self caretRect:&initialRect atOffset:handleOffset handler:aHandler]) {
+    mEditable.mShadowActiveHandleOffset = handleOffset;
+    mEditable.mShadowActiveHandleRect = initialRect;
+  }
+
+  [self computeLineBoundariesForOffset:handleOffset handler:aHandler];
+  [self computeVerticalBoundariesForOffset:handleOffset handler:aHandler];
+}
+
+// This is my own implementation for finding the visual line boundaries so that
+// dragging selection handles horizontally can be constrained within the current
+// line (just like the iOS native behavior).
+// I initially asked an LLM for how to best do this, but it just implement some
+// slop calculations, boundary checks, and bouncing back handles on every
+// interaction in closestPositionToPoint, which is just extremely slow and
+// unreliable.
+// So I came up with this instead. What's even better is that this is triggered
+// only once right after a word is selected, so it's fast. Still not a great
+// solution tbh, but it clearly works beautifully and reliably.
+- (void)computeLineBoundariesForOffset:(NSUInteger)aOffset
+                               handler:(widget::TextInputHandler*)aHandler {
+  mEditable.mLineBoundariesComputed = NO;
+  mEditable.mLineBoundaryStart = 0;
+  mEditable.mLineBoundaryEnd = [self documentLength];
+
+  if (!aHandler) {
+    return;
+  }
+
+  CGRect refRect;
+  if (![self caretRect:&refRect atOffset:aOffset handler:aHandler]) {
+    return;
+  }
+
+  const NSUInteger textLength = [self documentLength];
+
+  // Walk right until the caret moves to a different visual line.
+  NSUInteger rightBoundary = aOffset;
+  for (NSUInteger i = aOffset + 1; i <= textLength; i++) {
+    CGRect testRect;
+    if (![self caretRect:&testRect atOffset:i handler:aHandler]) {
+      break;
+    }
+    if (!RectsShareVisualLine(refRect, testRect)) {
+      break;
+    }
+    rightBoundary = i;
+  }
+
+  // Walk left until the caret moves to a different visual line.
+  NSUInteger leftBoundary = aOffset;
+  if (aOffset > 0) {
+    for (NSInteger i = (NSInteger)aOffset - 1; i >= 0; i--) {
+      CGRect testRect;
+      if (![self caretRect:&testRect atOffset:(NSUInteger)i handler:aHandler]) {
+        break;
+      }
+      if (!RectsShareVisualLine(refRect, testRect)) {
+        break;
+      }
+      leftBoundary = (NSUInteger)i;
+    }
+  }
+
+  mEditable.mLineBoundaryStart = leftBoundary;
+  mEditable.mLineBoundaryEnd = rightBoundary;
+  mEditable.mLineBoundariesComputed = YES;
+}
+
+// findClosestOffsetToX and computeVerticalBoundariesForOffset, are functions
+// which work together to implement the vertical dragging support.
+//
+// I thought of a simple implementation like this:
+// - When a handle is being dragged, continuously monitor the y position of the
+// finger's touch.
+// - Introduce a "vertical boundary". Says y1 is the y of the current line and
+// y2 is the y of the adjacent line. The vertical boundary will have a y of (y1
+// + y2) / 2. So the current line will have 2 vertical boundaries, one on top
+// and one on the bottom.
+// - Compare the y of the finger against these boundaries. So we keep horizontal
+// dragging activated if the finger's y is in between these boundaries;
+// otherwise, activate vertical dragging.
+// - For vertical dragging, immediately check if a character rect on the line
+// underneath the finger has the closest x to the finger's x, and move the
+// handle there immediately. If the line is too short (the right boundary is
+// smaller than the finger's x), just move the handle to the end of the line.
+//
+// This implementation takes advantage of the neighboring selection cache added
+// for line boundary checks. Got an LLM to help me write code based on this
+// and it just works so well with barely any adjustments.
+
+// Computes vertical boundaries for the current visual line. Each boundary
+// is the midpoint between the current line center and an adjacent line center.
+- (void)computeVerticalBoundariesForOffset:(NSUInteger)aOffset
+                                   handler:(widget::TextInputHandler*)aHandler {
+  mEditable.mVerticalBoundariesComputed = NO;
+  mEditable.mVerticalBoundaryTop = -CGFLOAT_MAX;
+  mEditable.mVerticalBoundaryBottom = CGFLOAT_MAX;
+
+  if (!aHandler || !mEditable.mLineBoundariesComputed) {
+    return;
+  }
+
+  CGRect refRect;
+  if (![self caretRect:&refRect atOffset:aOffset handler:aHandler]) {
+    return;
+  }
+
+  CGFloat currentMidY = CGRectGetMidY(refRect);
+
+  // Find the adjacent line above by looking one offset before the line start.
+  if (mEditable.mLineBoundaryStart > 0) {
+    CGRect aboveRect;
+    if ([self caretRect:&aboveRect
+               atOffset:mEditable.mLineBoundaryStart - 1
+                handler:aHandler]) {
+      CGFloat aboveMidY = CGRectGetMidY(aboveRect);
+      mEditable.mVerticalBoundaryTop = (currentMidY + aboveMidY) / 2.0;
+    }
+  }
+
+  // Find the adjacent line below by looking one offset past the line end.
+  const NSUInteger textLength = [self documentLength];
+  if (mEditable.mLineBoundaryEnd < textLength) {
+    CGRect belowRect;
+    if ([self caretRect:&belowRect
+               atOffset:mEditable.mLineBoundaryEnd + 1
+                handler:aHandler]) {
+      CGFloat belowMidY = CGRectGetMidY(belowRect);
+      mEditable.mVerticalBoundaryBottom = (currentMidY + belowMidY) / 2.0;
+    }
+  }
+
+  mEditable.mVerticalBoundariesComputed = YES;
+}
+
+// Scans offsets within a visual line and returns the one whose caret rect
+// is horizontally closest to aTargetX. Used after a vertical line jump.
+- (NSUInteger)findClosestOffsetToX:(CGFloat)aTargetX
+                       onLineStart:(NSUInteger)aLineStart
+                           lineEnd:(NSUInteger)aLineEnd
+                           handler:(widget::TextInputHandler*)aHandler {
+  NSUInteger bestOffset = aLineStart;
+  CGFloat bestDistance = CGFLOAT_MAX;
+
+  for (NSUInteger i = aLineStart; i <= aLineEnd; i++) {
+    CGRect rect;
+    if (![self caretRect:&rect atOffset:i handler:aHandler]) {
+      continue;
+    }
+    CGFloat dist = fabs(aTargetX - CGRectGetMinX(rect));
+    if (dist < bestDistance) {
+      bestDistance = dist;
+      bestOffset = i;
+    }
+  }
+
+  return bestOffset;
+}
+
+// Returns the current selected text range.
+- (UITextRange*)selectedTextRange {
+  if (mEditable.mActiveSelectionHandle != GeckoSelectionHandleNone &&
+      mEditable.mShadowSelectedRange.location != NSNotFound) {
+    return [self textRangeForRange:mEditable.mShadowSelectedRange];
+  }
+  if ([self hasVietnameseBuffer] &&
+      mEditable.mVietnameseBufferSelection.location != NSNotFound) {
+    return [self textRangeForExactRange:mEditable.mVietnameseBufferSelection];
+  }
+  NSRange range = [self selectedRange];
+  if (range.location == NSNotFound) {
+    return nil;
+  }
+  return [self textRangeForRange:range];
+}
+
+// Updates Gecko selection to match UIKit's selected text range.
+- (void)setSelectedTextRange:(UITextRange*)aSelectedTextRange {
+  NSRange range = [self rangeForTextRange:aSelectedTextRange];
+  if (range.location == NSNotFound) {
+    return;
+  }
+
+  if ([self hasVietnameseBuffer]) {
+    // Keep selection changes inside the buffer. Gecko will be updated when the
+    // keyboard commits an edit command against this selection.
+    NSUInteger bufferLength = [mEditable.mVietnameseBufferText length];
+    NSUInteger location = std::min(range.location, bufferLength);
+    NSUInteger length = std::min(range.length, bufferLength - location);
+    mEditable.mVietnameseBufferSelection = NSMakeRange(location, length);
+    if (length) {
+      mEditable.mVietnameseBufferMarkedRange =
+          mEditable.mVietnameseBufferSelection;
+    } else if (mEditable.mVietnameseBufferMarkedRange.location != NSNotFound &&
+               (location < mEditable.mVietnameseBufferMarkedRange.location ||
+                location >
+                    NSMaxRange(mEditable.mVietnameseBufferMarkedRange))) {
+      // If we move the caret outside the current marked range, that means we no
+      // longer do composing a word.
+      [self clearVietnameseMarkedRange];
+    }
+    return;
+  }
+
+  mEditable.mShadowSelectedRange = range;
+
+  if (range.length == 0 &&
+      mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone) {
+    [self resetHandleState];
+  }
+
+  if (mEditable.mCaretMenuActive) {
+    mEditable.mCaretMenuActive = NO;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return;
+  }
+
+  [mEditable.mTextInputDelegate selectionWillChange:self];
+  handler->SetSelectedRange(range);
+  [mEditable.mTextInputDelegate selectionDidChange:self];
+  if (mEditable.mSelectionDisplayInteraction == nil &&
+      mEditable.mActiveSelectionHandle != GeckoSelectionHandleNone) {
+    [NSObject
+        cancelPreviousPerformRequestsWithTarget:self
+                                       selector:@selector(resetHandleState)
+                                         object:nil];
+    [self performSelector:@selector(resetHandleState)
+               withObject:nil
+               afterDelay:0.25
+                  inModes:@[ NSRunLoopCommonModes ]];
+  }
+  if (mEditable.mSelectionDisplayInteraction != nil) {
+    [self updateEditMenu];
+  }
+}
+
+// Returns the anchor rect UIKit should use for the menus.
+- (CGRect)firstRectForRange:(UITextRange*)aRange {
+  NSRange queryRange = [self rangeForTextRange:aRange];
+  if (queryRange.location == NSNotFound) {
+    return CGRectZero;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return CGRectZero;
+  }
+
+  const EndpointRects rects = [self visibleHandleRectsForRange:queryRange
+                                                       handler:handler];
+
+  // Return only the first line if the selection spans multiple lines
+  if (queryRange.length > 0 && rects.hasStart && rects.hasEnd &&
+      !RectsShareVisualLine(rects.startRect, rects.endRect)) {
+    return rects.startRect;
+  }
+
+  LayoutDeviceIntRect rect;
+  // Menu anchors are Gecko rects; visible ranges from the Vietnamese buffer
+  // need Gecko-offset translation before asking for geometry.
+  NSRange geckoQueryRange = [self geckoRangeForVisibleRange:queryRange];
+  if (handler->TextRectForRange(geckoQueryRange, rect)) {
+    CGRect uiRect = DevPixelsToUIKitPoints(rect, [self contentScaleFactor]);
+    if ([self clipToSelectionBounds:&uiRect]) {
+      return uiRect;
+    }
+  }
+
+  return CGRectZero;
+}
+
+// Returns the caret rect for a text position.
+- (CGRect)caretRectForPosition:(UITextPosition*)aPosition {
+  ChildViewTextPosition* textPosition = [self textPosForPosition:aPosition];
+  if (!textPosition) {
+    return CGRectZero;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return CGRectZero;
+  }
+
+  NSRange selectedRange = [self hasVietnameseBuffer]
+                              ? mEditable.mVietnameseBufferSelection
+                              : [self selectedRange];
+  CGRect uiRect = CGRectZero;
+  GeckoSelectionHandle handle = GeckoSelectionHandleNone;
+  if (selectedRange.location != NSNotFound && selectedRange.length > 0) {
+    if (textPosition.offset == [self clampOffset:selectedRange.location]) {
+      handle = GeckoSelectionHandleStart;
+    } else if (textPosition.offset == [self clampOffset:selectedRange.location +
+                                                        selectedRange.length]) {
+      handle = GeckoSelectionHandleEnd;
+    }
+  }
+  if (![self handleRect:&uiRect
+               atOffset:textPosition.offset
+                 handle:handle
+                handler:handler]) {
+    return CGRectZero;
+  }
+
+  if (![self isRectFullyVisibleInSelectionBounds:uiRect]) {
+    return CGRectZero;
+  }
+  return uiRect;
+}
+
+// Multi-line selection highlight:
+// For each multi-line selection, we create 3 rects:
+//   1. Start line: from the start caret to the RIGHT editable boundary.
+//   2. Middle area: full width of the editable region between lines.
+//   3. End line: from the LEFT editable boundary to the end caret.
+// The -10000/10000 trick pushes offscreen handle endpoints far off the
+// display so they can be hidden automatically during scrolling/dragging.
+- (void)appendModernMultiLineRectsForStart:(CGRect)aStartRect
+                                       end:(CGRect)aEndRect
+                                    bounds:(CGRect)aBounds
+                             containsStart:(BOOL)aContainsStart
+                               containsEnd:(BOOL)aContainsEnd
+                                      into:(NSMutableArray*)aOut {
+  // Start-line highlight: from start caret to right editable boundary.
+  CGRect startHighlight =
+      CGRectMake(CGRectGetMinX(aStartRect), CGRectGetMinY(aStartRect),
+                 CGRectGetMaxX(aBounds) - CGRectGetMinX(aStartRect),
+                 CGRectGetHeight(aStartRect));
+  CGRect clippedStart = startHighlight;
+  if (!ClipCGRectToBounds(clippedStart, aBounds)) {
+    CGFloat offY =
+        CGRectGetMidY(aStartRect) < CGRectGetMidY(aBounds) ? -10000 : 10000;
+    clippedStart =
+        CGRectMake(CGRectGetMinX(aStartRect), offY, CGRectGetWidth(aStartRect),
+                   CGRectGetHeight(aStartRect));
+  }
+  AppendSelectionRect(aOut, clippedStart, aContainsStart, NO);
+
+  // Middle area: fill the gap between the start and end lines with a
+  // full-width rect spanning the editable bounds.
+  CGFloat middleTop = CGRectGetMaxY(aStartRect);
+  CGFloat middleBottom = CGRectGetMinY(aEndRect);
+  if (middleBottom > middleTop) {
+    CGRect middleRect =
+        CGRectMake(CGRectGetMinX(aBounds), middleTop, CGRectGetWidth(aBounds),
+                   middleBottom - middleTop);
+    CGRect clippedMiddle = middleRect;
+    if (ClipCGRectToBounds(clippedMiddle, aBounds)) {
+      AppendSelectionRect(aOut, clippedMiddle, NO, NO);
+    }
+  }
+
+  // End-line highlight: from left editable boundary to end caret.
+  CGRect endHighlight =
+      CGRectMake(CGRectGetMinX(aBounds), CGRectGetMinY(aEndRect),
+                 CGRectGetMaxX(aEndRect) - CGRectGetMinX(aBounds),
+                 CGRectGetHeight(aEndRect));
+  CGRect clippedEnd = endHighlight;
+  if (!ClipCGRectToBounds(clippedEnd, aBounds)) {
+    CGFloat offY =
+        CGRectGetMidY(aEndRect) < CGRectGetMidY(aBounds) ? -10000 : 10000;
+    clippedEnd =
+        CGRectMake(CGRectGetMinX(aEndRect), offY, CGRectGetWidth(aEndRect),
+                   CGRectGetHeight(aEndRect));
+  }
+  AppendSelectionRect(aOut, clippedEnd, NO, aContainsEnd);
+}
+
+- (void)appendLegacyMultiLineRectsForStart:(CGRect)aStartRect
+                                       end:(CGRect)aEndRect
+                                    bounds:(CGRect)aBounds
+                             containsStart:(BOOL)aContainsStart
+                               containsEnd:(BOOL)aContainsEnd
+                                      into:(NSMutableArray*)aOut {
+  const BOOL isDragging =
+      mEditable.mActiveSelectionHandle != GeckoSelectionHandleNone;
+
+  // Start-line highlight: from start caret to right editable boundary.
+  CGRect startHighlight =
+      CGRectMake(CGRectGetMinX(aStartRect), CGRectGetMinY(aStartRect),
+                 CGRectGetMaxX(aBounds) - CGRectGetMinX(aStartRect),
+                 CGRectGetHeight(aStartRect));
+  CGRect clippedStart = startHighlight;
+  if (!ClipCGRectToBounds(clippedStart, aBounds)) {
+    if (isDragging) {
+      CGFloat offY =
+          CGRectGetMidY(aStartRect) < CGRectGetMidY(aBounds) ? -10000 : 10000;
+      clippedStart =
+          CGRectMake(CGRectGetMinX(aStartRect), offY,
+                     CGRectGetWidth(aStartRect), CGRectGetHeight(aStartRect));
+    } else {
+      CGFloat clampedY =
+          fmax(CGRectGetMinY(aBounds),
+               fmin(CGRectGetMinY(aStartRect),
+                    CGRectGetMaxY(aBounds) - CGRectGetHeight(aStartRect)));
+      clippedStart =
+          CGRectMake(CGRectGetMinX(aStartRect), clampedY,
+                     CGRectGetMaxX(aBounds) - CGRectGetMinX(aStartRect),
+                     CGRectGetHeight(aStartRect));
+    }
+  }
+  AppendSelectionRect(aOut, clippedStart, aContainsStart, NO);
+
+  // Middle area: fill the gap between the start and end lines with a
+  // full-width rect spanning the editable bounds.
+  CGFloat middleTop = CGRectGetMaxY(aStartRect);
+  CGFloat middleBottom = CGRectGetMinY(aEndRect);
+  if (middleBottom > middleTop) {
+    CGRect middleRect =
+        CGRectMake(CGRectGetMinX(aBounds), middleTop, CGRectGetWidth(aBounds),
+                   middleBottom - middleTop);
+    CGRect clippedMiddle = middleRect;
+    if (ClipCGRectToBounds(clippedMiddle, aBounds)) {
+      AppendSelectionRect(aOut, clippedMiddle, NO, NO);
+    }
+  }
+
+  // End-line highlight: from left editable boundary to end caret.
+  CGRect endHighlight =
+      CGRectMake(CGRectGetMinX(aBounds), CGRectGetMinY(aEndRect),
+                 CGRectGetMaxX(aEndRect) - CGRectGetMinX(aBounds),
+                 CGRectGetHeight(aEndRect));
+  CGRect clippedEnd = endHighlight;
+  if (!ClipCGRectToBounds(clippedEnd, aBounds)) {
+    if (isDragging) {
+      CGFloat offY =
+          CGRectGetMidY(aEndRect) < CGRectGetMidY(aBounds) ? -10000 : 10000;
+      clippedEnd =
+          CGRectMake(CGRectGetMinX(aEndRect), offY, CGRectGetWidth(aEndRect),
+                     CGRectGetHeight(aEndRect));
+    } else {
+      CGFloat clampedY =
+          fmax(CGRectGetMinY(aBounds),
+               fmin(CGRectGetMinY(aEndRect),
+                    CGRectGetMaxY(aBounds) - CGRectGetHeight(aEndRect)));
+      clippedEnd = CGRectMake(CGRectGetMinX(aBounds), clampedY,
+                              CGRectGetMaxX(aEndRect) - CGRectGetMinX(aBounds),
+                              CGRectGetHeight(aEndRect));
+    }
+  }
+  AppendSelectionRect(aOut, clippedEnd, NO, aContainsEnd);
+}
+
+// Create UITextSelectionRect objects from Gecko's selection geometry, clipped
+// to the visible editor region.
+- (NSArray*)selectionRectsForRange:(UITextRange*)aRange {
+  NSRange queryRange = [self rangeForTextRange:aRange];
+  if (queryRange.location == NSNotFound) {
+    return [NSArray array];
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return [NSArray array];
+  }
+
+  CGRect visibleBounds = [self selectionBounds];
+  if (CGRectIsEmpty(visibleBounds) || CGRectIsNull(visibleBounds)) {
+    return [NSArray array];
+  }
+
+  NSMutableArray* selectionRects = [NSMutableArray array];
+
+  const NSUInteger startOffset = [self clampOffset:queryRange.location];
+  const NSUInteger endOffset =
+      [self clampOffset:queryRange.location + queryRange.length];
+  const GeckoSelectionHandle startHandle = queryRange.length > 0
+                                               ? GeckoSelectionHandleStart
+                                               : GeckoSelectionHandleNone;
+  const GeckoSelectionHandle endHandle = queryRange.length > 0
+                                             ? GeckoSelectionHandleEnd
+                                             : GeckoSelectionHandleNone;
+
+  // First try to describe the selection from its endpoints. That gives UIKit
+  // better information about which fragment contains the true start/end of the
+  // selection, which matters for handle placement and grabber visibility.
+  CGRect startRect = CGRectZero;
+  CGRect endRect = CGRectZero;
+  bool hasStartRect = [self handleRect:&startRect
+                              atOffset:startOffset
+                                handle:startHandle
+                               handler:handler];
+  bool hasEndRect = [self handleRect:&endRect
+                            atOffset:endOffset
+                              handle:endHandle
+                             handler:handler];
+
+  if (hasStartRect && hasEndRect) {
+    // ContentCacheInParent's mFirstCharRect is stale during handle drags:
+    // the cached rect for offset 0 can have wrong X and/or
+    // wrong Y/height. So we always normalize offset 0 against
+    // offset 1, which comes from the reliable text-rect cache window.
+    if (queryRange.length > 0 && startOffset == 0) {
+      CGRect nextRect;
+      if ([self handleRect:&nextRect
+                  atOffset:1
+                    handle:startHandle
+                   handler:handler]) {
+        // Always adopt Y and height from offset 1.
+        startRect.origin.y = nextRect.origin.y;
+        startRect.size.height = nextRect.size.height;
+        // If X is also stale (offset 0 to the right of offset 1), pin to
+        // the editor's left edge.
+        if (CGRectGetMinX(startRect) > CGRectGetMinX(nextRect)) {
+          startRect.origin.x = CGRectGetMinX(visibleBounds);
+        }
+      }
+    }
+
+    // Multi-line
+    if (!RectsShareVisualLine(startRect, endRect)) {
+      const BOOL containsStart =
+          [self isRectFullyVisibleInSelectionBounds:startRect];
+      const BOOL containsEnd =
+          [self isRectFullyVisibleInSelectionBounds:endRect];
+
+      if (mEditable.mSelectionDisplayInteraction == nil) {
+        [self appendLegacyMultiLineRectsForStart:startRect
+                                             end:endRect
+                                          bounds:visibleBounds
+                                   containsStart:containsStart
+                                     containsEnd:containsEnd
+                                            into:selectionRects];
+      } else {
+        [self appendModernMultiLineRectsForStart:startRect
+                                             end:endRect
+                                          bounds:visibleBounds
+                                   containsStart:containsStart
+                                     containsEnd:containsEnd
+                                            into:selectionRects];
+      }
+    } else {
+      // For a single-line selection, merge both endpoints into one span rect so
+      // UIKit sees the whole highlight as a single visual segment.
+      CGFloat minX = fmin(CGRectGetMinX(startRect), CGRectGetMinX(endRect));
+      CGFloat maxX = fmax(CGRectGetMaxX(startRect), CGRectGetMaxX(endRect));
+      CGRect spanRect = CGRectMake(minX, CGRectGetMinY(startRect), maxX - minX,
+                                   CGRectGetHeight(startRect));
+      const BOOL containsStart =
+          [self isRectFullyVisibleInSelectionBounds:startRect];
+      const BOOL containsEnd =
+          [self isRectFullyVisibleInSelectionBounds:endRect];
+      if (ClipCGRectToBounds(spanRect, visibleBounds)) {
+        AppendSelectionRect(selectionRects, spanRect, containsStart,
+                            containsEnd);
+      }
+    }
+  }
+
+  if ([selectionRects count] > 0) {
+    return selectionRects;
+  }
+
+  // If endpoint geometry is missing, fall back to Gecko's aggregate text rect.
+  LayoutDeviceIntRect rect;
+  NSRange geckoQueryRange = [self geckoRangeForVisibleRange:queryRange];
+  if (handler->TextRectForRange(geckoQueryRange, rect)) {
+    CGRect uiRect = DevPixelsToUIKitPoints(rect, [self contentScaleFactor]);
+    if (ClipCGRectToBounds(uiRect, visibleBounds)) {
+      AppendSelectionRect(selectionRects, uiRect, NO, NO);
+    }
+  }
+  return selectionRects;
+}
+
+// Converts a touch point into a document position. Pretty simple?
+// But this is the chosen candidate for lots of the work on selection dragging,
+// thanks to it being called on placing carets and selection drags, and as I do
+// research it seems like people usually use it to identify a tapped word on a
+// UITextInput?
+- (UITextPosition*)closestPositionToPoint:(CGPoint)aPoint {
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return [self endOfDocument];
+  }
+
+  NSRange selectedRange = [self selectedRange];
+
+  // If a drag is already active, use the shadow range so prevent the active
+  // handle from jumping around when Gecko's selection update lag behind.
+  if (mEditable.mActiveSelectionHandle != GeckoSelectionHandleNone &&
+      mEditable.mShadowSelectedRange.location != NSNotFound) {
+    selectedRange = mEditable.mShadowSelectedRange;
+  }
+
+  // Find the touched handle to start tracking
+  if (selectedRange.location != NSNotFound && selectedRange.length > 0) {
+    GeckoSelectionHandle touchedHandle =
+        [self closestHandleToPoint:aPoint range:selectedRange handler:handler];
+    // I initially did this "if" condition without
+    // (!(mEditable.mSelectionDisplayInteraction != nil) &&
+    // touchedHandle != mEditable.mActiveSelectionHandle). However, I ran into
+    // the problem where after dragging a handle, then release touch, then try
+    // to drag the opposite handle, the opposite handle just become
+    // unresponsive. So with that, the drag is prevented from staying pinned to
+    // the original active endpoint, and also forced to reselect the active
+    // handle when a different handle is touched.
+    if (touchedHandle != GeckoSelectionHandleNone &&
+        (mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone ||
+         (!(mEditable.mSelectionDisplayInteraction != nil) &&
+          touchedHandle != mEditable.mActiveSelectionHandle))) {
+      [self startHandleTrackingAtPoint:aPoint
+                                 range:selectedRange
+                               handler:handler];
+    }
+  }
+
+  NSUInteger candidateOffset = 0;
+  if (selectedRange.location != NSNotFound &&
+      mEditable.mActiveSelectionHandle != GeckoSelectionHandleNone &&
+      mEditable.mSelectionHandleAnchorOffset != NSNotFound) {
+    const NSUInteger textLength = [self documentLength];
+
+    // Here we use the shadow position as the base for calculations, because
+    // if we use Gecko's committed offsets (which are lagging behind), it may
+    // cause the handle to wiggle during dragging, especially during fast drags.
+    NSUInteger baseOffset = mEditable.mShadowActiveHandleOffset;
+    CGRect baseRect = mEditable.mShadowActiveHandleRect;
+
+    // When the finger's y crosses a vertical boundary (the midpoint
+    // between adjacent line centers), jump the handle to that line and
+    // position it at the character closest to the finger's x.
+    BOOL verticalJump = NO;
+    if (mEditable.mVerticalBoundariesComputed) {
+      BOOL crossedUp = aPoint.y < mEditable.mVerticalBoundaryTop;
+      BOOL crossedDown = aPoint.y > mEditable.mVerticalBoundaryBottom;
+      const NSUInteger anchor = mEditable.mSelectionHandleAnchorOffset;
+
+      NSUInteger iterations = 0;
+      while (crossedUp || crossedDown) {
+        if (++iterations > 50) {
+          break;
+        }
+
+        NSUInteger entryOffset = NSNotFound;
+        if (crossedUp && mEditable.mLineBoundaryStart > 0) {
+          entryOffset = mEditable.mLineBoundaryStart - 1;
+        } else if (crossedDown && mEditable.mLineBoundaryEnd < textLength) {
+          entryOffset = mEditable.mLineBoundaryEnd + 1;
+        }
+        if (entryOffset == NSNotFound) {
+          break;
+        }
+
+        CGRect unused;
+        if (![self caretRect:&unused atOffset:entryOffset handler:handler]) {
+          break;
+        }
+
+        // Save the current boundaries so we can revert if the new line
+        // turns out to be past the anchor (the handle cannot cross it).
+        const NSUInteger savedLineStart = mEditable.mLineBoundaryStart;
+        const NSUInteger savedLineEnd = mEditable.mLineBoundaryEnd;
+        const CGFloat savedVTop = mEditable.mVerticalBoundaryTop;
+        const CGFloat savedVBot = mEditable.mVerticalBoundaryBottom;
+        const BOOL savedVComputed = mEditable.mVerticalBoundariesComputed;
+
+        // Recompute horizontal and vertical boundaries for the new line.
+        [self computeLineBoundariesForOffset:entryOffset handler:handler];
+        [self computeVerticalBoundariesForOffset:entryOffset handler:handler];
+
+        // Check if the new line is entirely past the anchor. The end
+        // handle cannot go above a line that does not contain the anchor,
+        // and the start handle cannot go below such a line.
+        BOOL pastAnchor =
+            (mEditable.mActiveSelectionHandle == GeckoSelectionHandleEnd &&
+             mEditable.mLineBoundaryEnd < anchor) ||
+            (mEditable.mActiveSelectionHandle == GeckoSelectionHandleStart &&
+             mEditable.mLineBoundaryStart > anchor);
+
+        if (pastAnchor) {
+          // Revert to the previous boundaries and stop jumping.
+          mEditable.mLineBoundaryStart = savedLineStart;
+          mEditable.mLineBoundaryEnd = savedLineEnd;
+          mEditable.mLineBoundariesComputed = YES;
+          mEditable.mVerticalBoundaryTop = savedVTop;
+          mEditable.mVerticalBoundaryBottom = savedVBot;
+          mEditable.mVerticalBoundariesComputed = savedVComputed;
+          break;
+        }
+
+        verticalJump = YES;
+
+        // If the finger is still beyond the new line's vertical boundaries,
+        // continue jumping to the next line in the same direction.
+        crossedUp = mEditable.mVerticalBoundariesComputed &&
+                    aPoint.y < mEditable.mVerticalBoundaryTop;
+        crossedDown = mEditable.mVerticalBoundariesComputed &&
+                      aPoint.y > mEditable.mVerticalBoundaryBottom;
+      }
+
+      if (verticalJump) {
+        // Scan the new line to find the offset whose caret rect is
+        // horizontally closest to the finger. If the line is shorter
+        // than the finger's x, this naturally picks the last offset.
+        candidateOffset =
+            [self findClosestOffsetToX:aPoint.x
+                           onLineStart:mEditable.mLineBoundaryStart
+                               lineEnd:mEditable.mLineBoundaryEnd
+                               handler:handler];
+      }
+    }
+
+    if (!verticalJump) {
+      // Horizontal displacement logic for dragging within the same line.
+      const CGFloat charWidth = [self charWidthAtOffset:baseOffset
+                                              caretRect:baseRect
+                                                handler:handler];
+
+      // Keep the drag point inside the visible editor so the predicted endpoint
+      // does not jump randomly when the finger moves outside the editable.
+      CGFloat clampedPointX = aPoint.x;
+      CGRect editorBounds = [self selectionBounds];
+      if (!CGRectIsEmpty(editorBounds)) {
+        CGFloat margin = charWidth * 0.5;
+        clampedPointX =
+            fmax(CGRectGetMinX(editorBounds) - charWidth,
+                 fmin(CGRectGetMaxX(editorBounds) - margin, clampedPointX));
+      }
+
+      CGFloat displacement = clampedPointX - CGRectGetMinX(baseRect);
+      NSInteger step = (NSInteger)round(displacement / charWidth);
+      NSInteger newOffset = (NSInteger)baseOffset + step;
+      if (newOffset < 0) newOffset = 0;
+      if ((NSUInteger)newOffset > textLength) newOffset = textLength;
+      candidateOffset = (NSUInteger)newOffset;
+    }
+
+    // Clamp to line boundaries to prevent handle from jumping to adjacent
+    // lines during horizontal dragging.
+    if (mEditable.mLineBoundariesComputed) {
+      candidateOffset =
+          std::max(mEditable.mLineBoundaryStart,
+                   std::min(candidateOffset, mEditable.mLineBoundaryEnd));
+    }
+
+    // Cache the caret rect for the candidate offset, and correct stale
+    // mFirstCharRect from ContentCacheInParent at the line start.
+    CGRect shadowHandleRect;
+    if (![self caretRect:&shadowHandleRect
+                atOffset:candidateOffset
+                 handler:handler]) {
+      shadowHandleRect = baseRect;
+    }
+
+    if (candidateOffset == mEditable.mLineBoundaryStart &&
+        mEditable.mLineBoundariesComputed) {
+      CGRect eb = [self selectionBounds];
+      if (!CGRectIsEmpty(eb)) {
+        CGRect nextRect;
+        NSUInteger nextOff = candidateOffset + 1;
+        if (nextOff <= mEditable.mLineBoundaryEnd &&
+            [self caretRect:&nextRect atOffset:nextOff handler:handler] &&
+            CGRectGetMinX(shadowHandleRect) > CGRectGetMinX(nextRect)) {
+          // The first-char rect from the cache is to the right of the second
+          // character which is just clearly wrong. We use the editor's left
+          // edge instead.
+          shadowHandleRect.origin.x = CGRectGetMinX(eb);
+        }
+      }
+    }
+
+    NSUInteger anchor = mEditable.mSelectionHandleAnchorOffset;
+    candidateOffset = ClampTrackedSelectionOffset(
+        mEditable.mActiveSelectionHandle, candidateOffset, anchor);
+
+    // Enforce a minimum 1-character selection during handle drags so the
+    // ContentCache neighbourhood stays populated.
+    if (candidateOffset == anchor && mEditable.mLineBoundariesComputed) {
+      if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleStart &&
+          anchor > mEditable.mLineBoundaryStart) {
+        candidateOffset = anchor - 1;
+      } else if (mEditable.mActiveSelectionHandle == GeckoSelectionHandleEnd &&
+                 anchor < mEditable.mLineBoundaryEnd) {
+        candidateOffset = anchor + 1;
+      }
+    }
+
+    // Publish the predicted endpoint and the derived shadow selection for the
+    // rest of UITextInput until Gecko commits the same movement.
+    mEditable.mShadowActiveHandleOffset = candidateOffset;
+    mEditable.mShadowActiveHandleRect = shadowHandleRect;
+
+    NSUInteger lower = std::min(candidateOffset, anchor);
+    NSUInteger upper = std::max(candidateOffset, anchor);
+    mEditable.mShadowSelectedRange = NSMakeRange(lower, upper - lower);
+  }
+
+  return [ChildViewTextPosition positionWithOffset:candidateOffset];
+}
+
+// Toggle between editable and non-editable UITextInteraction
+// based on the current input context so native selection handles appear.
+- (void)updateTextInteractions {
+  if (mEditable.mSelectionDisplayInteraction != nil) {
+    [self updateModernTextInteractions];
+    return;
+  }
+  [self updateLegacyTextInteractions];
+}
+
+// Delay resigning first responder for one runloop turn so transient
+// focus handoffs inside the same editable or between editables do not dismiss
+// the keyboard, while a real outside tap still collapses it.
+- (void)scheduleResponderBlur {
+  [self cancelResponderBlur];
+  [self performSelector:@selector(applyResponderBlur)
+             withObject:nil
+             afterDelay:0
+                inModes:@[ NSRunLoopCommonModes ]];
+}
+
+// Cancel a queued blur when Gecko restores editable focus before the
+// deferred resign executes.
+- (void)cancelResponderBlur {
+  [NSObject
+      cancelPreviousPerformRequestsWithTarget:self
+                                     selector:@selector(applyResponderBlur)
+                                       object:nil];
+}
+
+// Apply the deferred blur once it is clear Gecko has not moved focus
+// back into an editable element.
+- (void)applyResponderBlur {
+  if (!mGeckoChild || mGeckoChild->Destroyed() || ![self isFirstResponder]) {
+    return;
+  }
+
+  [self resignFirstResponder];
+  [self updateEditMenu];
+}
+
+// Coalesce selection-geometry notifications so UIKit redraws
+// selection UI at most once per runloop turn.
+- (void)selectionGeometryChanged {
+  // If a caret-menu resolution is pending (from handleTap), check
+  // whether this position-change notification reflects an actual caret
+  // move. If the offset differs from the pre-tap offset, cancel the
+  // pending menu. If it matches, the caret stayed in place and the
+  // fallback timer will show the menu.
+  if (mEditable.mPendingCaretMenu) {
+    NSRange sel = [self selectedRange];
+    if (sel.location == NSNotFound || sel.length > 0 ||
+        labs((long)sel.location - (long)mEditable.mPreTapCaretOffset) > 1) {
+      mEditable.mPendingCaretMenu = NO;
+      [NSObject
+          cancelPreviousPerformRequestsWithTarget:self
+                                         selector:@selector(
+                                                      resolveCaretMenuIfPending)
+                                           object:nil];
+    }
+  }
+
+  if (mEditable.mSelectionDisplayInteraction != nil) {
+    [self refreshSelectionUI];
+  }
+  if (!mEditable.mTextInputDelegate) {
+    return;
+  }
+
+  if (mEditable.mPendingSelectionGeometryRefresh) {
+    return;
+  }
+  mEditable.mPendingSelectionGeometryRefresh = YES;
+  [self performSelector:@selector(applySelectionGeometryChange)
+             withObject:nil
+             afterDelay:0
+                inModes:@[ NSRunLoopCommonModes ]];
+}
+
+// Flushes the deferred selection-geometry notification.
+- (void)applySelectionGeometryChange {
+  mEditable.mPendingSelectionGeometryRefresh = NO;
+
+  if (!mEditable.mTextInputDelegate || !mGeckoChild ||
+      mGeckoChild->Destroyed()) {
+    return;
+  }
+  if (mEditable.mSelectionDisplayInteraction == nil) {
+    [mEditable.mTextInputDelegate selectionWillChange:self];
+  }
+  [mEditable.mTextInputDelegate selectionDidChange:self];
+  if (mEditable.mSelectionDisplayInteraction == nil) {
+    [NSObject
+        cancelPreviousPerformRequestsWithTarget:self
+                                       selector:@selector(updateLegacyGrabbers)
+                                         object:nil];
+    [self performSelector:@selector(updateLegacyGrabbers)
+               withObject:nil
+               afterDelay:0
+                  inModes:@[ NSRunLoopCommonModes ]];
+  }
+  [self updateEditMenu];
+}
+
+// Deferred selection-change notification after editing commands.
+- (void)scheduleEditSelectionUpdate {
+  if (mEditable.mSelectionDisplayInteraction != nil) {
+    [self refreshSelectionUI];
+  }
+  if (!mEditable.mTextInputDelegate) {
+    return;
+  }
+
+  [NSObject
+      cancelPreviousPerformRequestsWithTarget:self
+                                     selector:@selector(
+                                                  applyEditSelectionUpdate)
+                                       object:nil];
+  [self performSelector:@selector(applyEditSelectionUpdate)
+             withObject:nil
+             afterDelay:0
+                inModes:@[ NSRunLoopCommonModes ]];
+}
+
+// Flushes the deferred selection-change notification after editing.
+- (void)applyEditSelectionUpdate {
+  if (!mEditable.mTextInputDelegate || !mGeckoChild ||
+      mGeckoChild->Destroyed()) {
+    return;
+  }
+  // If the Vietnamese buffer is still ahead of Gecko, keep the deferred
+  // selection notification alive until the two states match.
+  widget::TextInputHandler* handler =
+      [self hasVietnameseBuffer] ? [self textHandler] : nullptr;
+  if (handler && ![self tryClearSyncedVietnameseBufferWithHandler:handler]) {
+    [NSObject
+        cancelPreviousPerformRequestsWithTarget:self
+                                       selector:@selector(
+                                                    applyEditSelectionUpdate)
+                                         object:nil];
+    [self performSelector:@selector(applyEditSelectionUpdate)
+               withObject:nil
+               afterDelay:0.03
+                  inModes:@[ NSRunLoopCommonModes ]];
+  }
+  if (mEditable.mSelectionDisplayInteraction != nil) {
+    [self refreshSelectionUI];
+  }
+  [mEditable.mTextInputDelegate selectionDidChange:self];
+  if (mEditable.mSelectionDisplayInteraction != nil) {
+    [self updateEditMenu];
+  }
+}
+
+// Shows the "Select All | Paste" callout.
+- (void)resolveCaretMenuIfPending {
+  if (!mEditable.mPendingCaretMenu) {
+    return;
+  }
+  mEditable.mPendingCaretMenu = NO;
+  mEditable.mCaretMenuActive = YES;
+  [self updateEditMenu];
+}
+
+// Keeps UIMenuController aligned with the current editable selection state.
+// The menu is shown when:
+//   - there is a non-empty selection (copy/cut/paste), or
+//   - the caret menu flag is active (select-all/paste after re-tap).
+- (void)updateEditMenu {
+  widget::TextInputHandler* handler = [self textHandler];
+  UIMenuController* menuController = [UIMenuController sharedMenuController];
+  if (!handler || ![self isFirstResponder]) {
+    [menuController hideMenuFromView:self];
+    return;
+  }
+
+  NSRange selectedRange = NSMakeRange(NSNotFound, 0);
+  if (!handler->SelectedRange(selectedRange) ||
+      selectedRange.location == NSNotFound) {
+    [menuController hideMenuFromView:self];
+    return;
+  }
+
+  // Non-empty selection: show menu anchored to the selection rect,
+  // but suppress it while a handle drag is in progress.
+  if (selectedRange.length > 0) {
+    mEditable.mCaretMenuActive = NO;
+    if (mEditable.mActiveSelectionHandle != GeckoSelectionHandleNone) {
+      [menuController hideMenuFromView:self];
+      return;
+    }
+    ChildViewTextRange* range = [self textRangeForRange:selectedRange];
+    if (!range) {
+      [menuController hideMenuFromView:self];
+      return;
+    }
+    CGRect targetRect = [self firstRectForRange:range];
+    if (CGRectIsEmpty(targetRect)) {
+      [menuController hideMenuFromView:self];
+      return;
+    }
+    [menuController showMenuFromView:self rect:targetRect];
+    return;
+  }
+
+  // Collapsed caret: show menu only when the caret-menu flag is set.
+  if (mEditable.mCaretMenuActive) {
+    LayoutDeviceIntRect caretDevRect;
+    if (handler->CaretRectForOffset(selectedRange.location, caretDevRect)) {
+      CGRect caretRect =
+          DevPixelsToUIKitPoints(caretDevRect, [self contentScaleFactor]);
+      if (!CGRectIsEmpty(caretRect)) {
+        [menuController showMenuFromView:self rect:caretRect];
+        return;
+      }
+    }
+  }
+
+  [menuController hideMenuFromView:self];
+}
+
+// Returns the plain text inside a UITextRange.
+- (NSString*)textInRange:(UITextRange*)aRange {
+  NSRange queryRange = [self rangeForTextRange:aRange];
+  if (queryRange.location == NSNotFound) {
+    return @"";
+  }
+
+  NSString* bufferText = [self vietnameseBufferTextInRange:queryRange];
+  if (bufferText) {
+    // UITextInput ask for the just-edited Vietnamese text before Gecko has
+    // finished applying it. Return the buffer for that short window.
+    return bufferText;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return @"";
+  }
+
+  nsString text;
+  if (!handler->TextInRange(queryRange, text)) {
+    return @"";
+  }
+
+  return [NSString
+      stringWithCharacters:reinterpret_cast<const unichar*>(text.BeginReading())
+                    length:text.Length()];
+}
+
+// Replaces the text inside a UITextRange.
+- (void)replaceRange:(UITextRange*)aRange withText:(NSString*)aText {
+  NSRange replacementRange = [self rangeForTextRange:aRange];
+  if (replacementRange.location == NSNotFound) {
+    return;
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return;
+  }
+
+  if ([self hasVietnameseBuffer]) {
+    handler->ReplaceRange([self geckoRangeForVisibleRange:replacementRange],
+                          aText ?: @"");
+    [self replaceVietnameseBufferRange:replacementRange withText:aText ?: @""];
+    return;
+  }
+
+  [mEditable.mTextInputDelegate textWillChange:self];
+  [mEditable.mTextInputDelegate selectionWillChange:self];
+  handler->ReplaceRange(replacementRange, aText ?: @"");
+  [mEditable.mTextInputDelegate textDidChange:self];
+  [mEditable.mTextInputDelegate selectionDidChange:self];
+}
+
+// Reports which edit actions should appear in the menu.
+- (BOOL)canPerformAction:(SEL)aAction withSender:(id)aSender {
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return [super canPerformAction:aAction withSender:aSender];
+  }
+
+  NSRange selection = NSMakeRange(NSNotFound, 0);
+  handler->SelectedRange(selection);
+  const bool hasSelection =
+      selection.location != NSNotFound && selection.length > 0;
+  const uint32_t length = [self documentLength];
+
+  if (aAction == @selector(copy:)) {
+    return hasSelection;
+  }
+  if (aAction == @selector(cut:)) {
+    return hasSelection;
+  }
+  if (aAction == @selector(paste:)) {
+    return [UIPasteboard generalPasteboard].hasStrings;
+  }
+  if (aAction == @selector(delete:)) {
+    return hasSelection;
+  }
+  if (aAction == @selector(selectAll:)) {
+    return length > 0 &&
+           !(selection.location == 0 && selection.length == length);
+  }
+
+  return [super canPerformAction:aAction withSender:aSender];
+}
+
+- (void)copy:(id)aSender {
+  if (widget::TextInputHandler* handler = [self textHandler]) {
+    handler->RunCommand(eContentCommandCopy, false);
+  }
+}
+
+- (void)cut:(id)aSender {
+  if (widget::TextInputHandler* handler = [self textHandler]) {
+    [mEditable.mTextInputDelegate textWillChange:self];
+    [mEditable.mTextInputDelegate selectionWillChange:self];
+    handler->RunCommand(eContentCommandCut, false);
+    [mEditable.mTextInputDelegate textDidChange:self];
+    [mEditable.mTextInputDelegate selectionDidChange:self];
+    [self scheduleEditSelectionUpdate];
+  }
+}
+
+- (void)paste:(id)aSender {
+  if (widget::TextInputHandler* handler = [self textHandler]) {
+    [mEditable.mTextInputDelegate textWillChange:self];
+    [mEditable.mTextInputDelegate selectionWillChange:self];
+    handler->RunCommand(eContentCommandPaste, false);
+    [mEditable.mTextInputDelegate textDidChange:self];
+    [mEditable.mTextInputDelegate selectionDidChange:self];
+    [self scheduleEditSelectionUpdate];
+  }
+}
+
+- (void)delete:(id)aSender {
+  if (widget::TextInputHandler* handler = [self textHandler]) {
+    [mEditable.mTextInputDelegate textWillChange:self];
+    handler->RunCommand(eContentCommandDelete, false);
+    [mEditable.mTextInputDelegate textDidChange:self];
+    [self scheduleEditSelectionUpdate];
+  }
+}
+
+- (void)selectAll:(id)aSender {
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return;
+  }
+
+  uint32_t length = 0;
+  if (!handler->TextLength(length)) {
+    return;
+  }
+
+  [mEditable.mTextInputDelegate selectionWillChange:self];
+  handler->SetSelectedRange(NSMakeRange(0, length));
+  [mEditable.mTextInputDelegate selectionDidChange:self];
+}
