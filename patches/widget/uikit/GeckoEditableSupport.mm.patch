+- (UITextRange*)markedTextRange {
+  // Vietnamese IM use the marked range to keep the composing word active while
+  // accents are being decided.
+  if ([self hasVietnameseBuffer] &&
+      mEditable.mVietnameseBufferMarkedRange.location != NSNotFound &&
+      mEditable.mActiveSelectionHandle == GeckoSelectionHandleNone) {
+    NSUInteger bufferLength = [mEditable.mVietnameseBufferText length];
+    NSRange range = mEditable.mVietnameseBufferMarkedRange;
+    if (range.location != NSNotFound && range.location <= bufferLength &&
+        range.length <= bufferLength - range.location) {
+      return [self textRangeForExactRange:range];
+    }
+    [self clearVietnameseMarkedRange];
+  }
+
+  widget::TextInputHandler* handler = [self textHandler];
+  if (!handler) {
+    return nil;
+  }
+
+  NSRange range = NSMakeRange(NSNotFound, 0);
+  if (!handler->MarkedRange(range) || range.location == NSNotFound) {
+    return nil;
+  }
+
+  return [self textRangeForExactRange:range];
+}
